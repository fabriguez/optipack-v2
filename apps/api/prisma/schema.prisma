generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ORGANISATION
// ============================================================

model Organization {
  id              String   @id @default(uuid())
  name            String
  address         String?
  phone           String?
  email           String?
  logoUrl         String?
  // Branding tenant : controle par l'admin du tenant via /settings/branding
  primaryColor    String   @default("#1B5E20") // primary-900 (vert fonce)
  secondaryColor  String   @default("#4CAF50") // primary-500 (vert moyen)
  accentColor     String   @default("#E8F5E9") // primary-50 (vert clair)
  // Modules actives pour ce tenant. Vide = tous actifs (compat ascendante).
  enabledModules  String[] @default([])
  defaultCurrency String   @default("XAF")
  defaultLanguage String   @default("fr")
  supportEmail    String?
  // Slug unique pour matcher subdomain (acme.transitsoftservices.com)
  slug            String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  agencies      Agency[]
  users         User[]
  clients       Client[]
  transitRoutes TransitRoute[]
  currencies    Currency[]
  accounts      AccountingAccount[]
  loyaltyTiers  LoyaltyTierConfig[]
  systemConfigs SystemConfig[]

  @@map("organizations")
}

// ============================================================
// AGENCES
// ============================================================

model Agency {
  id                String   @id @default(uuid())
  organizationId    String
  name              String
  code              String   @unique
  address           String
  city              String
  country           String
  phone             String
  email             String?
  imageUrl          String?
  // Cle de l'objet MinIO (pour pouvoir le supprimer/remplacer). Sert d'audit interne ;
  // pas exposee a l'API publique. Si NULL et imageUrl est set, c'est une URL externe.
  imageKey          String?
  googleMapsLink    String?
  responsibleUserId String?
  // Fuseau horaire IANA (ex: "Africa/Douala"). Sert au calcul de fin de journee
  // pour la fermeture automatique de caisse.
  timezone          String   @default("Africa/Douala")
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization    Organization         @relation(fields: [organizationId], references: [id])
  responsibleUser User?                @relation("AgencyResponsible", fields: [responsibleUserId], references: [id])
  openingHours    AgencyOpeningHours[]

  warehouses            Warehouse[]
  userAgencies          UserAgency[]
  employees             Employee[]
  clients               Client[]
  departureContainers   Container[]           @relation("DepartureAgency")
  arrivalContainers     Container[]           @relation("ArrivalAgency")
  parcelsAsDestination  Parcel[]              @relation("ParcelDestinationAgency")
  invoices              Invoice[]
  payments              Payment[]
  cashRegisters         AgencyCashRegister[]
  disbursements         DisbursementVoucher[]
  fundTransfersSent     FundTransfer[]        @relation("SourceAgency")
  fundTransfersReceived FundTransfer[]        @relation("DestinationAgencyRel")
  expenses              Expense[]
  penalties             Penalty[]
  journalEntries        JournalEntry[]
  auditLogs             AuditLog[]
  chatConversations     ChatConversation[]
  notifications         Notification[]
  charges               AgencyCharge[]
  dailyReports          AgencyDailyReport[]

  @@index([organizationId])
  @@index([city])
  @@map("agencies")
}

// Rapport journalier d'une agence.
// Genere automatiquement a la fermeture de caisse (auto ou manuelle), il agrege :
//  - colis recus dans la journee, par categorie et par route de transit
//  - somme du reste a payer pour chaque colis
//  - paiements recus par route et par mode de paiement
//  - total decaissements
// Les observations utilisateur (texte, images, xlsx, pdf) sont stockees dans
// AgencyDailyReportAttachment + champ `observation` pour completer le rapport.
model AgencyDailyReport {
  id          String                  @id @default(uuid())
  agencyId    String
  // Date du jour rapporte (00:00 UTC, comme AgencyCashRegister.date)
  date        DateTime                @db.Date
  // Snapshot JSON pour eviter de recalculer (immutable apres cloture)
  // Contient : { byCategory, byTransitRoute, paymentsByRouteAndMethod,
  //             disbursementsByCategory, totalParcels, totalRemainingAmount, ... }
  payload     Json
  // Status: GENERATED (cron auto), CLOSED (cloture manuelle/auto), AMENDED (observation ajoutee).
  status      AgencyDailyReportStatus @default(GENERATED)
  // Texte libre saisi par l'utilisateur (peut etre tres long, formatte en markdown plain)
  observation String?
  generatedAt DateTime                @default(now())
  closedAt    DateTime?
  closedBy    String?

  agency       Agency                        @relation(fields: [agencyId], references: [id])
  closedByUser User?                         @relation("DailyReportClosedBy", fields: [closedBy], references: [id])
  attachments  AgencyDailyReportAttachment[]

  @@unique([agencyId, date])
  @@index([agencyId])
  @@index([date])
  @@map("agency_daily_reports")
}

enum AgencyDailyReportStatus {
  GENERATED
  CLOSED
  AMENDED
}

// Pieces jointes d'un rapport journalier : images, xlsx, pdf, etc.
model AgencyDailyReportAttachment {
  id          String   @id @default(uuid())
  reportId    String
  url         String
  storageKey  String?
  fileName    String?
  contentType String?
  size        Int?
  caption     String?
  uploadedBy  String?
  createdAt   DateTime @default(now())

  report   AgencyDailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  uploader User?             @relation("DailyReportAttachmentBy", fields: [uploadedBy], references: [id])

  @@index([reportId])
  @@map("agency_daily_report_attachments")
}

// Plage horaire d'ouverture d'une agence pour un jour de la semaine.
// dayOfWeek = 0 (dimanche) .. 6 (samedi). Plusieurs lignes possibles par jour
// (ex : 8h-12h puis 14h-18h).
model AgencyOpeningHours {
  id        String   @id @default(uuid())
  agencyId  String
  dayOfWeek Int
  // Format HH:mm (24h, ex : "08:00", "18:30"). Vide -> agence fermee ce jour.
  openTime  String
  closeTime String
  // Active le jour ; si false, ce jour est ferme meme avec des creneaux configures.
  isOpen    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([agencyId, dayOfWeek])
  @@map("agency_opening_hours")
}

// Charge recurrente d'une agence : eau, electricite, loyer, masse salariale, internet...
// Sert de configuration : chaque mois, l'utilisateur enregistre un paiement (Expense)
// rattache a la charge via Expense.agencyChargeId + Expense.period (YYYY-MM).
// La charge elle-meme est mutable (montant et echeance peuvent evoluer) ; les paiements
// passent par le ledger immuable Expense (regle finance).
model AgencyCharge {
  id               String     @id @default(uuid())
  agencyId         String
  type             ChargeType
  label            String
  defaultAmount    Decimal    @db.Decimal(15, 2)
  // jour du mois ou la charge est due (1-31). Optionnel.
  dueDayOfMonth    Int?
  // commentaire ou reference (n compteur eau, contrat de bail, ...)
  reference        String?
  // Indique que le montant n'est pas fixe (ex: facture d'eau, electricite).
  // L'UI propose de saisir un montant a chaque paiement plutot que de prefiller
  // avec defaultAmount. Pour le calcul de "charges dues", on prend max(defaultAmount, 0).
  isAmountFlexible Boolean    @default(false)
  // Charge auto-geree par le systeme (ex : masse salariale = somme des salaires).
  // Si true, l'utilisateur ne peut pas modifier defaultAmount manuellement ;
  // le serveur recalcule le montant a chaque ajout/MAJ d'employe.
  isAutoManaged    Boolean    @default(false)
  isActive         Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  agency    Agency                 @relation(fields: [agencyId], references: [id])
  expenses  Expense[]
  documents AgencyChargeDocument[]
  history   AgencyChargeHistory[]

  // Une seule charge auto-geree par agence et par type (ex: une seule SALARY auto)
  @@unique([agencyId, type, isAutoManaged])
  @@index([agencyId])
  @@index([type])
  @@map("agency_charges")
}

// Documents attaches a une charge (factures, contrats, releves, ...).
// Ces documents servent de justificatifs et peuvent etre uploades a la creation
// ou ajoutes ulterieurement (ex: facture d'eau du mois).
model AgencyChargeDocument {
  id          String   @id @default(uuid())
  chargeId    String
  url         String
  // Cle MinIO pour pouvoir supprimer / re-uploader. Optionnel pour les liens externes.
  storageKey  String?
  fileName    String?
  contentType String?
  size        Int?
  caption     String?
  uploadedBy  String?
  createdAt   DateTime @default(now())

  charge   AgencyCharge @relation(fields: [chargeId], references: [id], onDelete: Cascade)
  uploader User?        @relation("ChargeDocUploader", fields: [uploadedBy], references: [id])

  @@index([chargeId])
  @@map("agency_charge_documents")
}

// Audit log des modifications d'une charge (creation, MAJ champs, paiements,
// activation/desactivation). Sert d'historique pour la consultation utilisateur.
model AgencyChargeHistory {
  id        String   @id @default(uuid())
  chargeId  String
  action    String // CREATED, UPDATED, PAID, DEACTIVATED, REACTIVATED, DOCUMENT_ADDED, ...
  // Snapshot des champs modifies (avant / apres) ou metadonnees (montant paye, periode...).
  changes   Json?
  comment   String?
  userId    String?
  createdAt DateTime @default(now())

  charge AgencyCharge @relation(fields: [chargeId], references: [id], onDelete: Cascade)
  user   User?        @relation("ChargeHistoryUser", fields: [userId], references: [id])

  @@index([chargeId])
  @@index([action])
  @@map("agency_charge_history")
}

enum ChargeType {
  WATER
  ELECTRICITY
  RENT
  SALARY
  INTERNET
  PHONE
  CLEANING
  SECURITY
  MAINTENANCE
  OTHER
}

// ============================================================
// MAGASINS / ENTREPOTS
// ============================================================

model Warehouse {
  id        String   @id @default(uuid())
  agencyId  String
  name      String
  location  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agency          Agency               @relation(fields: [agencyId], references: [id])
  parcels         Parcel[]             @relation("CurrentWarehouse")
  originalParcels Parcel[]             @relation("OriginalWarehouse")
  inventories     WarehouseInventory[]

  @@index([agencyId])
  @@map("warehouses")
}

// Inventaire d'un magasin : declenche par un operateur, on scanne les colis
// presents physiquement, puis on cloture pour reconcilier avec le stock theorique.
model WarehouseInventory {
  id          String                   @id @default(uuid())
  warehouseId String
  status      WarehouseInventoryStatus @default(IN_PROGRESS)
  startedById String?
  closedById  String?
  startedAt   DateTime                 @default(now())
  closedAt    DateTime?
  comment     String?

  warehouse Warehouse                @relation(fields: [warehouseId], references: [id])
  startedBy User?                    @relation("InventoryStartedBy", fields: [startedById], references: [id])
  closedBy  User?                    @relation("InventoryClosedBy", fields: [closedById], references: [id])
  items     WarehouseInventoryItem[]

  @@index([warehouseId])
  @@index([status])
  @@map("warehouse_inventories")
}

enum WarehouseInventoryStatus {
  IN_PROGRESS
  CLOSED
  CANCELLED
}

// Une ligne par colis scanne / detecte pendant l'inventaire.
// expected = colis dans le stock theorique au moment du demarrage
// scanned  = a-t-il ete vu pendant l'inventaire
model WarehouseInventoryItem {
  id          String    @id @default(uuid())
  inventoryId String
  parcelId    String
  expected    Boolean   @default(true)
  scanned     Boolean   @default(false)
  scannedAt   DateTime?
  scannedById String?
  comment     String?

  inventory WarehouseInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  parcel    Parcel             @relation(fields: [parcelId], references: [id])
  scannedBy User?              @relation("InventoryItemScannedBy", fields: [scannedById], references: [id])

  @@unique([inventoryId, parcelId])
  @@index([inventoryId])
  @@index([parcelId])
  @@map("warehouse_inventory_items")
}

// ============================================================
// UTILISATEURS
// ============================================================

model User {
  id               String    @id @default(uuid())
  organizationId   String
  email            String    @unique
  passwordHash     String
  firstName        String
  lastName         String
  phone            String?
  avatarUrl        String?
  role             UserRole  @default(AGENT)
  isActive         Boolean   @default(true)
  isVerified       Boolean   @default(false)
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  userAgencies           UserAgency[]
  responsibleAgencies    Agency[]                      @relation("AgencyResponsible")
  refreshTokens          RefreshToken[]
  paymentsReceived       Payment[]
  voidedPayments         Payment[]                     @relation("VoidedByUser")
  disbursementsIssued    DisbursementVoucher[]         @relation("IssuedByUser")
  disbursementsApproved  DisbursementVoucher[]         @relation("ApprovedByUser")
  transfersInitiated     FundTransfer[]                @relation("InitiatedByUser")
  transfersConfirmed     FundTransfer[]                @relation("ConfirmedByUser")
  closedCashRegisters    AgencyCashRegister[]
  journalEntriesCreated  JournalEntry[]
  expensesApproved       Expense[]
  parcelHistories        ParcelHistory[]
  containerHistories     ContainerHistory[]
  auditLogs              AuditLog[]
  chatMessagesAgent      ChatMessage[]
  assignedConversations  ChatConversation[]
  inventoriesStarted     WarehouseInventory[]          @relation("InventoryStartedBy")
  inventoriesClosed      WarehouseInventory[]          @relation("InventoryClosedBy")
  inventoryItemsScanned  WarehouseInventoryItem[]      @relation("InventoryItemScannedBy")
  chargeDocsUploaded     AgencyChargeDocument[]        @relation("ChargeDocUploader")
  chargeHistoryActions   AgencyChargeHistory[]         @relation("ChargeHistoryUser")
  dailyReportsClosed     AgencyDailyReport[]           @relation("DailyReportClosedBy")
  dailyReportAttachments AgencyDailyReportAttachment[] @relation("DailyReportAttachmentBy")

  @@index([organizationId])
  @@index([email])
  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  AGENT
  COMPTABLE
  MAGASINIER
  SUPERVISEUR
}

model UserAgency {
  userId   String
  agencyId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@id([userId, agencyId])
  @@map("user_agencies")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ============================================================
// EMPLOYES
// ============================================================

model Employee {
  id              String    @id @default(uuid())
  agencyId        String
  fullName        String
  idNumber        String?
  phone           String?
  position        String
  level           String?
  baseSalary      Decimal   @default(0) @db.Decimal(15, 2)
  startDate       DateTime  @default(now())
  endDate         DateTime?
  // Photos employe : selfie (visage), plan (localisation domicile),
  // document d'identification (CNI, passeport...). Toutes uploadees via /employees/:id/image
  selfieUrl       String?
  selfieKey       String?
  locationPlanUrl String?
  locationPlanKey String?
  idDocumentUrl   String?
  idDocumentKey   String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  agency   Agency    @relation(fields: [agencyId], references: [id])
  payslips Payslip[]

  @@index([agencyId])
  @@map("employees")
}

model Payslip {
  id                  String    @id @default(uuid())
  employeeId          String
  period              String
  baseSalary          Decimal   @db.Decimal(15, 2)
  bonuses             Decimal   @default(0) @db.Decimal(15, 2)
  benefitsInKind      Decimal   @default(0) @db.Decimal(15, 2)
  socialContributions Decimal   @default(0) @db.Decimal(15, 2)
  grossSalary         Decimal   @db.Decimal(15, 2)
  netSalary           Decimal   @db.Decimal(15, 2)
  isPaid              Boolean   @default(false)
  // Date effective du paiement (nul tant que isPaid=false). Mise a jour
  // lorsqu'on declenche PayEmployeeFromCashRegisterUseCase.
  paidAt              DateTime?
  // Reference vers l'Expense de paiement (immutable). Permet de remonter
  // depuis le payslip vers la caisse qui a ete debitee.
  paidExpenseId       String?   @unique

  generatedAt DateTime @default(now())

  employee    Employee @relation(fields: [employeeId], references: [id])
  paidExpense Expense? @relation("PayslipPaidExpense", fields: [paidExpenseId], references: [id])

  @@index([employeeId])
  @@map("payslips")
}

// ============================================================
// CLIENTS
// ============================================================

model Client {
  id             String      @id @default(uuid())
  organizationId String
  agencyId       String
  fullName       String
  phone          String      @unique
  email          String?
  idNumber       String?
  imageUrl       String?
  address        String?
  clientType     ClientType  @default(INDIVIDUAL)
  loyaltyTier    LoyaltyTier @default(STANDARD)
  loyaltyPoints  Int         @default(0)
  totalSpent     Decimal     @default(0) @db.Decimal(15, 2)
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Auth fields for client portal
  passwordHash   String?
  isPortalActive Boolean @default(false)

  organization        Organization[]
  agency              Agency               @relation(fields: [agencyId], references: [id])
  parcels             Parcel[]             @relation("ParcelClient")
  parcelsAsRecipient  Parcel[]             @relation("ParcelRecipient")
  invoices            Invoice[]
  debts               Debt[]
  loyaltyTransactions LoyaltyTransaction[]
  penalties           Penalty[]
  chatConversations   ChatConversation[]
  notifications       Notification[]       @relation("ClientNotifications")
  partnerPricings     PartnerPricing[]

  @@index([organizationId])
  @@index([agencyId])
  @@index([phone])
  @@index([clientType])
  @@map("clients")
}

enum ClientType {
  INDIVIDUAL
  COMPANY
  PARTNER
}

enum LoyaltyTier {
  STANDARD
  SILVER
  GOLD
  VIP
}

// Tarification specifique par partenaire (override des prix de la TransitRoute)
model PartnerPricing {
  id             String   @id @default(uuid())
  clientId       String
  transitRouteId String?
  pricePerKg     Decimal  @db.Decimal(15, 2)
  pricePerVolume Decimal  @default(0) @db.Decimal(15, 2)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  transitRoute TransitRoute? @relation(fields: [transitRouteId], references: [id])

  @@unique([clientId, transitRouteId])
  @@index([clientId])
  @@map("partner_pricings")
}

// NOTE : ancien modele Recipient fusionne dans Client.
// Un client peut maintenant etre a la fois expediteur (Parcel.client) et
// destinataire (Parcel.recipient via la meme table). Les anciens recipients
// ont ete migres en Client (cf. migration *_merge_recipients_into_clients).

// ============================================================
// ROUTES DE TRANSIT
// ============================================================

model TransitRoute {
  id                    String      @id @default(uuid())
  organizationId        String
  name                  String
  type                  TransitType
  departureCity         String
  departureCountry      String
  arrivalCity           String
  arrivalCountry        String
  pricePerKg            Decimal     @db.Decimal(15, 2)
  pricePerVolume        Decimal     @default(0) @db.Decimal(15, 2)
  estimatedDurationDays Int         @default(0)
  isActive              Boolean     @default(true)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id])
  parcels         Parcel[]
  containers      Container[]
  partnerPricings PartnerPricing[]

  @@index([organizationId])
  @@map("transit_routes")
}

enum TransitType {
  AIR
  SEA
  LAND
}

// ============================================================
// CONTENEURS
// ============================================================

model Container {
  id                   String          @id @default(uuid())
  // organizationId pour isolation multi-tenant
  organizationId       String
  designation          String
  type                 TransitType
  isForwarding         Boolean         @default(false)
  // Hierarchie : un conteneur d'acheminement (isForwarding=true) peut etre place
  // dans un conteneur parent AIR/SEA. Le parent ne peut pas etre lui-meme forwarding.
  parentContainerId    String?
  // Transporteur (facultatif) : nom/reference de la compagnie/personne en charge.
  carrier              String?
  capacity             Decimal         @db.Decimal(15, 2)
  // currentLoad : valeur snapshot, peut driver. Repository la recalcule a la lecture.
  currentLoad          Decimal         @default(0) @db.Decimal(15, 2)
  transitRouteId       String?
  departureAgencyId    String
  arrivalAgencyId      String
  status               ContainerStatus @default(EMPTY)
  loadingDate          DateTime?
  departureDate        DateTime?
  estimatedArrivalDate DateTime?
  actualArrivalDate    DateTime?
  isDeleted            Boolean         @default(false)
  deletedAt            DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  transitRoute     TransitRoute?         @relation(fields: [transitRouteId], references: [id])
  departureAgency  Agency                @relation("DepartureAgency", fields: [departureAgencyId], references: [id])
  arrivalAgency    Agency                @relation("ArrivalAgency", fields: [arrivalAgencyId], references: [id])
  parentContainer  Container?            @relation("ContainerHierarchy", fields: [parentContainerId], references: [id])
  childContainers  Container[]           @relation("ContainerHierarchy")
  parcels          Parcel[]              @relation("CurrentContainer")
  lastContainerFor Parcel[]              @relation("LastContainer")
  histories        ContainerHistory[]
  manifests        ShippingManifest[]
  expenses         Expense[]
  routingSource    InterAgencyRouting[]  @relation("SourceContainer")
  routingTarget    InterAgencyRouting[]  @relation("TargetContainer")
  discrepancies    ManifestDiscrepancy[]

  @@unique([organizationId, designation])
  @@index([organizationId])
  @@index([departureAgencyId])
  @@index([arrivalAgencyId])
  @@index([status])
  @@index([parentContainerId])
  @@map("containers")
}

// Cycle de vie simplifie a 5 statuts (audit fix #3) :
// EMPTY -> LOADING -> IN_TRANSIT -> RECEIVED -> UNLOADED (terminal)
// Les anciens ARRIVED + UNLOADING sont migres vers RECEIVED.
enum ContainerStatus {
  EMPTY
  LOADING
  IN_TRANSIT
  RECEIVED
  UNLOADED
}

// ============================================================
// COLIS
// ============================================================

model Parcel {
  id                  String       @id @default(uuid())
  // organizationId : isolation multi-tenant
  organizationId      String
  trackingNumber      String       @unique
  designation         String
  weight              Decimal?     @db.Decimal(15, 3)
  originalWeight      Decimal?     @db.Decimal(15, 3)
  volume              Decimal?     @db.Decimal(15, 3)
  imageUrl            String?
  qrCodeUrl           String?
  origin              String?
  // Destination structuree (audit fix #1) :
  // - destination = ville d'arrivee (legacy / pre-rempli depuis transitRoute.arrivalCity)
  // - destinationAgencyId = agence physique de reception (peut etre NULL si livraison directe)
  // - destinationAddress = adresse precise libre (rue, quartier)
  destination         String
  destinationAgencyId String?
  destinationAddress  String?
  observation         String?
  originalObservation String?
  status              ParcelStatus @default(IN_STOCK)
  isPresent           Boolean      @default(true)
  price               Decimal      @default(0) @db.Decimal(15, 2)

  // Categorie + flags metiers (audit fix #10)
  category      ParcelCategory @default(STANDARD)
  isFragile     Boolean        @default(false)
  isHazardous   Boolean        @default(false)
  declaredValue Decimal?       @db.Decimal(15, 2) // pour assurance

  clientId            String
  recipientId         String?
  warehouseId         String?
  originalWarehouseId String?
  containerId         String?
  lastContainerId     String?
  transitRouteId      String?
  // invoiceId : NON unique. Une facture peut couvrir N colis (audit fix #5).
  invoiceId           String?

  arrivalDate        DateTime?
  pickupDate         DateTime?
  penaltyStartDate   DateTime?
  warehouseEnteredAt DateTime?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  client            Client        @relation("ParcelClient", fields: [clientId], references: [id])
  recipient         Client?       @relation("ParcelRecipient", fields: [recipientId], references: [id])
  warehouse         Warehouse?    @relation("CurrentWarehouse", fields: [warehouseId], references: [id])
  originalWarehouse Warehouse?    @relation("OriginalWarehouse", fields: [originalWarehouseId], references: [id])
  destinationAgency Agency?       @relation("ParcelDestinationAgency", fields: [destinationAgencyId], references: [id])
  container         Container?    @relation("CurrentContainer", fields: [containerId], references: [id])
  lastContainer     Container?    @relation("LastContainer", fields: [lastContainerId], references: [id])
  transitRoute      TransitRoute? @relation(fields: [transitRouteId], references: [id])
  invoice           Invoice?      @relation(fields: [invoiceId], references: [id])

  histories      ParcelHistory[]
  manifestLines  ManifestLine[]
  penalties      Penalty[]
  routings       InterAgencyRouting[]
  images         ParcelImage[]
  discrepancies  ManifestDiscrepancy[]
  inventoryItems WarehouseInventoryItem[]

  @@index([organizationId])
  @@index([clientId])
  @@index([warehouseId])
  @@index([containerId])
  @@index([destinationAgencyId])
  @@index([invoiceId])
  @@index([status])
  @@index([trackingNumber])
  @@index([category])
  @@map("parcels")
}

// Categorie metier du colis (audit fix #10)
enum ParcelCategory {
  STANDARD
  DOCUMENT
  FOOD
  ELECTRONICS
  CLOTHING
  OTHER
}

// Galerie d'images d'un colis (multi-images)
model ParcelImage {
  id        String   @id @default(uuid())
  parcelId  String
  url       String
  caption   String?
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  parcel Parcel @relation(fields: [parcelId], references: [id], onDelete: Cascade)

  @@index([parcelId])
  @@map("parcel_images")
}

enum ParcelStatus {
  IN_STOCK
  LOADING
  IN_TRANSIT
  ARRIVED
  RECEIVED
  DELIVERED
  LOST
}

// ============================================================
// ROUTAGE INTER-AGENCES
// ============================================================

model InterAgencyRouting {
  id                String        @id @default(uuid())
  sourceContainerId String
  targetContainerId String?
  parcelId          String
  sourceAgencyId    String
  targetAgencyId    String
  targetCity        String
  routingStatus     RoutingStatus @default(PENDING)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  sourceContainer Container  @relation("SourceContainer", fields: [sourceContainerId], references: [id])
  targetContainer Container? @relation("TargetContainer", fields: [targetContainerId], references: [id])
  parcel          Parcel     @relation(fields: [parcelId], references: [id])

  @@index([sourceContainerId])
  @@index([parcelId])
  @@map("inter_agency_routings")
}

enum RoutingStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
}

// ============================================================
// FACTURATION
// ============================================================

model Invoice {
  id          String        @id @default(uuid())
  reference   String        @unique
  clientId    String
  agencyId    String
  totalAmount Decimal       @db.Decimal(15, 2)
  discount    Decimal       @default(0) @db.Decimal(15, 2)
  tva         Decimal       @default(0) @db.Decimal(15, 2)
  netAmount   Decimal       @db.Decimal(15, 2)
  paidAmount  Decimal       @default(0) @db.Decimal(15, 2)
  balance     Decimal       @db.Decimal(15, 2)
  currency    String        @default("XAF")
  status      InvoiceStatus @default(UNPAID)
  dueDate     DateTime?
  issuedAt    DateTime      @default(now())
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  client   Client    @relation(fields: [clientId], references: [id])
  agency   Agency    @relation(fields: [agencyId], references: [id])
  // 1 facture peut couvrir N colis (audit fix #5)
  parcels  Parcel[]
  payments Payment[]
  debts    Debt[]

  @@index([clientId])
  @@index([agencyId])
  @@index([status])
  @@map("invoices")
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
  CANCELLED
}

// ============================================================
// PAIEMENTS (IMMUTABLE)
// ============================================================

model Payment {
  id                   String        @id @default(uuid())
  reference            String        @unique
  invoiceId            String
  agencyId             String
  amount               Decimal       @db.Decimal(15, 2)
  discount             Decimal       @default(0) @db.Decimal(15, 2)
  discountReason       String?
  tva                  Decimal       @default(0) @db.Decimal(15, 2)
  paymentMethod        PaymentMethod
  transactionReference String?
  receivedByUserId     String

  // Immutabilite : pas de updatedAt, void seulement
  isVoided       Boolean   @default(false)
  voidedAt       DateTime?
  voidReason     String?
  voidedByUserId String?

  createdAt DateTime @default(now())
  // PAS de updatedAt -- paiement immutable

  invoice    Invoice @relation(fields: [invoiceId], references: [id])
  agency     Agency  @relation(fields: [agencyId], references: [id])
  receivedBy User    @relation(fields: [receivedByUserId], references: [id])
  voidedBy   User?   @relation("VoidedByUser", fields: [voidedByUserId], references: [id])

  @@index([invoiceId])
  @@index([agencyId])
  @@index([createdAt])
  @@map("payments")
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  BANK_TRANSFER
  CARD
  CHECK
}

// ============================================================
// CAISSE AGENCE
// ============================================================

model AgencyCashRegister {
  id             String    @id @default(uuid())
  agencyId       String
  date           DateTime  @default(now()) @db.Date
  openingBalance Decimal   @db.Decimal(15, 2)
  totalEntries   Decimal   @default(0) @db.Decimal(15, 2)
  totalExits     Decimal   @default(0) @db.Decimal(15, 2)
  currentBalance Decimal   @db.Decimal(15, 2)
  isClosed       Boolean   @default(false)
  closedAt       DateTime?
  closedByUserId String?
  closingBalance Decimal?  @db.Decimal(15, 2)
  notes          String?
  imageUrl       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  agency   Agency @relation(fields: [agencyId], references: [id])
  closedBy User?  @relation(fields: [closedByUserId], references: [id])

  disbursements DisbursementVoucher[]
  expenses      Expense[]

  @@unique([agencyId, date])
  @@index([agencyId])
  @@map("agency_cash_registers")
}

// ============================================================
// BONS DE DECAISSEMENT (IMMUTABLE)
// ============================================================

model DisbursementVoucher {
  id               String  @id @default(uuid())
  reference        String  @unique
  agencyId         String
  cashRegisterId   String
  reason           String
  description      String?
  orderer          String
  amount           Decimal @db.Decimal(15, 2)
  amountInWords    String
  proofUrl         String?
  issuedByUserId   String
  approvedByUserId String?

  // Immutabilite
  isVoided       Boolean   @default(false)
  voidedAt       DateTime?
  voidReason     String?
  reverseEntryId String?   @unique

  createdAt DateTime @default(now())
  // PAS de updatedAt -- immutable

  agency       Agency               @relation(fields: [agencyId], references: [id])
  cashRegister AgencyCashRegister   @relation(fields: [cashRegisterId], references: [id])
  issuedBy     User                 @relation("IssuedByUser", fields: [issuedByUserId], references: [id])
  approvedBy   User?                @relation("ApprovedByUser", fields: [approvedByUserId], references: [id])
  reverseEntry DisbursementVoucher? @relation("ReverseVoucher", fields: [reverseEntryId], references: [id])
  reversedBy   DisbursementVoucher? @relation("ReverseVoucher")

  @@index([agencyId])
  @@index([cashRegisterId])
  @@map("disbursement_vouchers")
}

// ============================================================
// TRANSFERTS DE FONDS (IMMUTABLE)
// ============================================================

model FundTransfer {
  id                  String                  @id @default(uuid())
  reference           String                  @unique
  sourceAgencyId      String
  destinationType     TransferDestinationType
  destinationAgencyId String?
  destinationLabel    String?
  amount              Decimal                 @db.Decimal(15, 2)
  transferMethod      String
  proofImageUrl       String?
  initiatedByUserId   String
  confirmedByUserId   String?
  status              TransferStatus          @default(PENDING)

  // Immutabilite
  isVoided       Boolean   @default(false)
  voidedAt       DateTime?
  voidReason     String?
  reverseEntryId String?   @unique

  createdAt DateTime @default(now())
  // PAS de updatedAt -- immutable

  sourceAgency      Agency        @relation("SourceAgency", fields: [sourceAgencyId], references: [id])
  destinationAgency Agency?       @relation("DestinationAgencyRel", fields: [destinationAgencyId], references: [id])
  initiatedBy       User          @relation("InitiatedByUser", fields: [initiatedByUserId], references: [id])
  confirmedBy       User?         @relation("ConfirmedByUser", fields: [confirmedByUserId], references: [id])
  reverseEntry      FundTransfer? @relation("ReverseTransfer", fields: [reverseEntryId], references: [id])
  reversedBy        FundTransfer? @relation("ReverseTransfer")

  @@index([sourceAgencyId])
  @@index([status])
  @@map("fund_transfers")
}

enum TransferDestinationType {
  HQ
  BANK
  AGENCY
}

enum TransferStatus {
  PENDING
  CONFIRMED
  VOIDED
}

// ============================================================
// DEPENSES
// ============================================================

model Expense {
  id               String   @id @default(uuid())
  agencyId         String
  title            String
  reason           String
  description      String?
  category         String?
  orderer          String?
  amount           Decimal  @db.Decimal(15, 2)
  receiptUrl       String?
  justificationUrl String?
  containerId      String?
  parcelId         String?
  associationType  String?
  approvedByUserId String?
  // Lien optionnel vers une charge recurrente (eau, electricite, loyer, ...)
  agencyChargeId   String?
  // Periode de la charge au format YYYY-MM (ex : "2025-11"). Permet de detecter
  // les charges deja payees pour un mois donne (= idempotence metier).
  period           String?
  // Caisse depuis laquelle le paiement a ete effectue. Permet de remonter
  // depuis l'Expense vers le compte qui a ete debite, et inversement.
  cashRegisterId   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  agency       Agency              @relation(fields: [agencyId], references: [id])
  container    Container?          @relation(fields: [containerId], references: [id])
  approvedBy   User?               @relation(fields: [approvedByUserId], references: [id])
  agencyCharge AgencyCharge?       @relation(fields: [agencyChargeId], references: [id])
  cashRegister AgencyCashRegister? @relation(fields: [cashRegisterId], references: [id])
  paidPayslip  Payslip?            @relation("PayslipPaidExpense")

  @@index([agencyId])
  @@index([agencyChargeId, period])
  @@index([cashRegisterId])
  @@map("expenses")
}

// ============================================================
// DETTES
// ============================================================

model Debt {
  id               String         @id @default(uuid())
  clientId         String
  invoiceId        String?
  creditor         String?
  description      String
  paymentMethod    PaymentMethod?
  paymentProofUrl  String?
  totalAmount      Decimal        @db.Decimal(15, 2)
  remainingAmount  Decimal        @db.Decimal(15, 2)
  installmentCount Int?
  installmentPlan  Json?
  nextDueDate      DateTime?
  status           DebtStatus     @default(ACTIVE)
  isCleared        Boolean        @default(false)
  alertSent        Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  client  Client   @relation(fields: [clientId], references: [id])
  invoice Invoice? @relation(fields: [invoiceId], references: [id])

  @@index([clientId])
  @@index([status])
  @@map("debts")
}

enum DebtStatus {
  ACTIVE
  PARTIALLY_PAID
  CLEARED
  OVERDUE
}

// ============================================================
// COMPTABILITE
// ============================================================

model AccountingAccount {
  id             String      @id @default(uuid())
  organizationId String
  code           String      @unique
  name           String
  type           AccountType
  parentId       String?
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id])
  parent       AccountingAccount?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children     AccountingAccount[] @relation("AccountHierarchy")
  debitLines   JournalEntryLine[]  @relation("DebitAccount")
  creditLines  JournalEntryLine[]  @relation("CreditAccount")

  @@index([organizationId])
  @@map("accounting_accounts")
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

model JournalEntry {
  id              String            @id @default(uuid())
  reference       String            @unique
  description     String
  date            DateTime          @default(now())
  agencyId        String
  createdByUserId String
  sourceType      JournalSourceType
  sourceId        String

  // Immutabilite
  isReversed        Boolean @default(false)
  reversedByEntryId String? @unique

  createdAt DateTime @default(now())
  // PAS de updatedAt -- immutable

  agency       Agency             @relation(fields: [agencyId], references: [id])
  createdBy    User               @relation(fields: [createdByUserId], references: [id])
  lines        JournalEntryLine[]
  reverseEntry JournalEntry?      @relation("ReverseJournalEntry", fields: [reversedByEntryId], references: [id])
  reversedBy   JournalEntry?      @relation("ReverseJournalEntry")

  @@index([agencyId])
  @@index([sourceType, sourceId])
  @@index([date])
  @@map("journal_entries")
}

enum JournalSourceType {
  PAYMENT
  DISBURSEMENT
  TRANSFER
  EXPENSE
  PENALTY
  SALARY
}

model JournalEntryLine {
  id              String   @id @default(uuid())
  journalEntryId  String
  debitAccountId  String?
  creditAccountId String?
  debitAmount     Decimal  @default(0) @db.Decimal(15, 2)
  creditAmount    Decimal  @default(0) @db.Decimal(15, 2)
  description     String?
  createdAt       DateTime @default(now())

  journalEntry  JournalEntry       @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  debitAccount  AccountingAccount? @relation("DebitAccount", fields: [debitAccountId], references: [id])
  creditAccount AccountingAccount? @relation("CreditAccount", fields: [creditAccountId], references: [id])

  @@index([journalEntryId])
  @@map("journal_entry_lines")
}

// ============================================================
// PENALITES
// ============================================================

model Penalty {
  id              String   @id @default(uuid())
  parcelId        String
  agencyId        String
  clientId        String
  startDate       DateTime
  dailyRate       Decimal  @db.Decimal(15, 2)
  daysAccumulated Int      @default(0)
  totalAmount     Decimal  @default(0) @db.Decimal(15, 2)
  isPaid          Boolean  @default(false)
  invoiceId       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  parcel Parcel @relation(fields: [parcelId], references: [id])
  agency Agency @relation(fields: [agencyId], references: [id])
  client Client @relation(fields: [clientId], references: [id])

  @@index([parcelId])
  @@index([clientId])
  @@map("penalties")
}

// ============================================================
// BORDEREAUX
// ============================================================

model ShippingManifest {
  id          String         @id @default(uuid())
  containerId String
  number      String         @unique
  type        ManifestType
  status      ManifestStatus @default(ACTIVE)
  closedAt    DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  container Container      @relation(fields: [containerId], references: [id])
  lines     ManifestLine[]

  @@index([containerId])
  @@map("shipping_manifests")
}

enum ManifestType {
  DISPATCH
  RECEPTION
}

enum ManifestStatus {
  ACTIVE
  ARCHIVED
  CANCELLED
}

model ManifestLine {
  id              String   @id @default(uuid())
  manifestId      String
  parcelId        String?
  // Snapshot des donnees du colis au moment de l'emission (immuable)
  trackingNumber  String?
  designation     String
  clientName      String?
  recipientName   String?
  destinationCity String?
  weight          Decimal? @db.Decimal(15, 3)
  volume          Decimal? @db.Decimal(15, 3)
  origin          String?
  destination     String?
  transit         String?
  price           Decimal  @default(0) @db.Decimal(15, 2)
  // montant total facture (peut etre > price si la facture couvre plusieurs colis)
  invoiceTotal    Decimal? @db.Decimal(15, 2)
  // avance / montant deja paye attribue a ce colis
  advanceAmount   Decimal  @default(0) @db.Decimal(15, 2)
  // reste a payer
  balanceAmount   Decimal  @default(0) @db.Decimal(15, 2)
  status          String?
  addedAt         DateTime @default(now())

  manifest ShippingManifest @relation(fields: [manifestId], references: [id], onDelete: Cascade)
  parcel   Parcel?          @relation(fields: [parcelId], references: [id])

  @@index([manifestId])
  @@map("manifest_lines")
}

// Ecarts marques par l'admin lors de la reception d'un conteneur
// (colis presents physiquement mais pas en ligne, ou en ligne mais absents physiquement)
model ManifestDiscrepancy {
  id             String          @id @default(uuid())
  containerId    String
  parcelId       String?
  type           DiscrepancyType
  designation    String?
  trackingNumber String?
  weight         Decimal?        @db.Decimal(15, 3)
  comment        String?
  markedByUserId String?
  createdAt      DateTime        @default(now())

  container Container @relation(fields: [containerId], references: [id])
  parcel    Parcel?   @relation(fields: [parcelId], references: [id])

  @@index([containerId])
  @@index([type])
  @@map("manifest_discrepancies")
}

enum DiscrepancyType {
  MISSING_PHYSICAL // declare en ligne mais absent physiquement
  EXTRA_PHYSICAL // present physiquement mais non enregistre en ligne
}

// ============================================================
// HISTORIQUE / AUDIT
// ============================================================

model ParcelHistory {
  id                        String   @id @default(uuid())
  parcelId                  String
  action                    String
  statusBefore              String?
  statusAfter               String?
  wasPresentBefore          Boolean?
  isPresentAfter            Boolean?
  locationBefore            String?
  locationAfter             String?
  warehouseId               String?
  containerId               String?
  transitRouteId            String?
  userId                    String?
  actorType                 String?
  actorName                 String?
  parcelDesignationSnapshot String?
  parcelTrackingSnapshot    String?
  comment                   String?
  metadata                  Json?
  createdAt                 DateTime @default(now())

  parcel Parcel @relation(fields: [parcelId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@index([parcelId])
  @@index([createdAt])
  @@map("parcel_histories")
}

model ContainerHistory {
  id           String   @id @default(uuid())
  containerId  String
  action       String
  statusBefore String?
  statusAfter  String?
  changes      Json?
  userId       String?
  actorType    String?
  actorName    String?
  comment      String?
  createdAt    DateTime @default(now())

  container Container @relation(fields: [containerId], references: [id])
  user      User?     @relation(fields: [userId], references: [id])

  @@index([containerId])
  @@index([createdAt])
  @@map("container_histories")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  agencyId   String?
  action     String
  entityType String
  entityId   String?
  changes    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  agency Agency? @relation(fields: [agencyId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String             @id @default(uuid())
  userId    String?
  clientId  String?
  agencyId  String?
  title     String
  message   String
  type      NotificationType
  status    NotificationStatus @default(PENDING)
  sentAt    DateTime?
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime           @default(now())

  agency Agency? @relation(fields: [agencyId], references: [id])
  client Client? @relation("ClientNotifications", fields: [clientId], references: [id])

  @@index([userId])
  @@index([clientId])
  @@index([status])
  @@map("notifications")
}

enum NotificationType {
  EMAIL
  SMS
  WHATSAPP
  PUSH
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

// ============================================================
// CHAT / SUPPORT
// ============================================================

model ChatConversation {
  id             String             @id @default(uuid())
  clientId       String
  agencyId       String
  assignedUserId String?
  status         ConversationStatus @default(OPEN)
  createdAt      DateTime           @default(now())
  closedAt       DateTime?

  client       Client        @relation(fields: [clientId], references: [id])
  agency       Agency        @relation(fields: [agencyId], references: [id])
  assignedUser User?         @relation(fields: [assignedUserId], references: [id])
  messages     ChatMessage[]

  @@index([clientId])
  @@index([status])
  @@map("chat_conversations")
}

enum ConversationStatus {
  OPEN
  CLOSED
}

model ChatMessage {
  id             String    @id @default(uuid())
  conversationId String
  senderId       String
  senderType     String
  message        String
  isRead         Boolean   @default(false)
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUser   User?            @relation(fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([createdAt])
  @@map("chat_messages")
}

// ============================================================
// FIDELITE
// ============================================================

model LoyaltyTransaction {
  id          String   @id @default(uuid())
  clientId    String
  points      Int
  type        String
  source      String?
  description String?
  createdAt   DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@map("loyalty_transactions")
}

model LoyaltyTierConfig {
  id              String   @id @default(uuid())
  organizationId  String
  name            String
  minPoints       Int
  discountPercent Decimal  @db.Decimal(5, 2)
  benefits        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, name])
  @@map("loyalty_tier_configs")
}

// ============================================================
// DEVISES
// ============================================================

model Currency {
  id             String   @id @default(uuid())
  organizationId String
  code           String
  name           String
  symbol         String
  exchangeRate   Decimal  @db.Decimal(15, 6)
  isBase         Boolean  @default(false)
  isActive       Boolean  @default(true)
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, code])
  @@map("currencies")
}

// ============================================================
// CONFIGURATION SYSTEME
// ============================================================

model SystemConfig {
  id             String   @id @default(uuid())
  organizationId String
  key            String
  value          String
  description    String?
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, key])
  @@map("system_configs")
}
