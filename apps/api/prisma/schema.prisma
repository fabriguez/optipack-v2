generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ORGANISATION
// ============================================================

model Organization {
  id              String   @id @default(uuid())
  name            String
  address         String?
  phone           String?
  email           String?
  logoUrl         String?
  // Branding tenant : controle par l'admin du tenant via /settings/branding
  primaryColor    String   @default("#1B5E20") // primary-900 (vert fonce)
  secondaryColor  String   @default("#4CAF50") // primary-500 (vert moyen)
  accentColor     String   @default("#E8F5E9") // primary-50 (vert clair)
  // Modules actives pour ce tenant. Vide = tous actifs (compat ascendante).
  enabledModules  String[] @default([])
  defaultCurrency String   @default("XAF")
  defaultLanguage String   @default("fr")
  supportEmail    String?
  // Slug unique pour matcher subdomain (acme.transitsoftservices.com)
  slug            String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  agencies      Agency[]
  users         User[]
  clients       Client[]
  transitRoutes TransitRoute[]
  currencies    Currency[]
  accounts      AccountingAccount[]
  loyaltyTiers  LoyaltyTierConfig[]
  systemConfigs SystemConfig[]

  @@map("organizations")
}

// ============================================================
// AGENCES
// ============================================================

model Agency {
  id                String   @id @default(uuid())
  organizationId    String
  name              String
  code              String   @unique
  address           String
  city              String
  country           String
  phone             String
  email             String?
  imageUrl          String?
  // Cle de l'objet MinIO (pour pouvoir le supprimer/remplacer). Sert d'audit interne ;
  // pas exposee a l'API publique. Si NULL et imageUrl est set, c'est une URL externe.
  imageKey          String?
  googleMapsLink    String?
  responsibleUserId String?
  // Fuseau horaire IANA (ex: "Africa/Douala"). Sert au calcul de fin de journee
  // pour la fermeture automatique de caisse.
  timezone          String   @default("Africa/Douala")
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Planning RH par defaut de l'agence (heures et jours de service du personnel).
  // Distinct des heures d'ouverture commerciale (openingHours). Le personnel sans
  // override (Employee.scheduleId IS NULL) suit ce planning.
  workScheduleId String?

  organization        Organization               @relation(fields: [organizationId], references: [id])
  responsibleUser     User?                      @relation("AgencyResponsible", fields: [responsibleUserId], references: [id])
  openingHours        AgencyOpeningHours[]
  workSchedule        WorkSchedule?              @relation("AgencyWorkSchedule", fields: [workScheduleId], references: [id])
  positions           Position[]
  holidays            Holiday[]                  @relation("AgencyHoliday")
  employeeAssignments EmployeeAgencyAssignment[]

  warehouses            Warehouse[]
  userAgencies          UserAgency[]
  employees             Employee[]
  clients               Client[]
  departureContainers   Container[]           @relation("DepartureAgency")
  arrivalContainers     Container[]           @relation("ArrivalAgency")
  parcelsAsDestination  Parcel[]              @relation("ParcelDestinationAgency")
  invoices              Invoice[]
  payments              Payment[]
  cashRegisters         AgencyCashRegister[]
  disbursements         DisbursementVoucher[]
  fundTransfersSent     FundTransfer[]        @relation("SourceAgency")
  fundTransfersReceived FundTransfer[]        @relation("DestinationAgencyRel")
  expenses              Expense[]
  penalties             Penalty[]
  journalEntries        JournalEntry[]
  auditLogs             AuditLog[]
  chatConversations     ChatConversation[]
  notifications         Notification[]
  charges               AgencyCharge[]
  dailyReports          AgencyDailyReport[]
  reviewConfig          AgencyReviewConfig?   @relation("AgencyReviewConfig")
  parcelGroups          ParcelGroup[]

  @@index([organizationId])
  @@index([city])
  @@map("agencies")
}

// Rapport journalier d'une agence.
// Genere automatiquement a la fermeture de caisse (auto ou manuelle), il agrege :
//  - colis recus dans la journee, par categorie et par route de transit
//  - somme du reste a payer pour chaque colis
//  - paiements recus par route et par mode de paiement
//  - total decaissements
// Les observations utilisateur (texte, images, xlsx, pdf) sont stockees dans
// AgencyDailyReportAttachment + champ `observation` pour completer le rapport.
model AgencyDailyReport {
  id          String                  @id @default(uuid())
  agencyId    String
  // Date du jour rapporte (00:00 UTC, comme AgencyCashRegister.date)
  date        DateTime                @db.Date
  // Snapshot JSON pour eviter de recalculer (immutable apres cloture)
  // Contient : { byCategory, byTransitRoute, paymentsByRouteAndMethod,
  //             disbursementsByCategory, totalParcels, totalRemainingAmount, ... }
  payload     Json
  // Status: GENERATED (cron auto), CLOSED (cloture manuelle/auto), AMENDED (observation ajoutee).
  status      AgencyDailyReportStatus @default(GENERATED)
  // Texte libre saisi par l'utilisateur (peut etre tres long, formatte en markdown plain)
  observation String?
  generatedAt DateTime                @default(now())
  closedAt    DateTime?
  closedBy    String?

  agency       Agency                        @relation(fields: [agencyId], references: [id])
  closedByUser User?                         @relation("DailyReportClosedBy", fields: [closedBy], references: [id])
  attachments  AgencyDailyReportAttachment[]

  @@unique([agencyId, date])
  @@index([agencyId])
  @@index([date])
  @@map("agency_daily_reports")
}

enum AgencyDailyReportStatus {
  GENERATED
  CLOSED
  AMENDED
}

// Pieces jointes d'un rapport journalier : images, xlsx, pdf, etc.
model AgencyDailyReportAttachment {
  id          String   @id @default(uuid())
  reportId    String
  url         String
  storageKey  String?
  fileName    String?
  contentType String?
  size        Int?
  caption     String?
  uploadedBy  String?
  createdAt   DateTime @default(now())

  report   AgencyDailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  uploader User?             @relation("DailyReportAttachmentBy", fields: [uploadedBy], references: [id])

  @@index([reportId])
  @@map("agency_daily_report_attachments")
}

// Plage horaire d'ouverture d'une agence pour un jour de la semaine.
// dayOfWeek = 0 (dimanche) .. 6 (samedi). Plusieurs lignes possibles par jour
// (ex : 8h-12h puis 14h-18h).
model AgencyOpeningHours {
  id        String   @id @default(uuid())
  agencyId  String
  dayOfWeek Int
  // Format HH:mm (24h, ex : "08:00", "18:30"). Vide -> agence fermee ce jour.
  openTime  String
  closeTime String
  // Active le jour ; si false, ce jour est ferme meme avec des creneaux configures.
  isOpen    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([agencyId, dayOfWeek])
  @@map("agency_opening_hours")
}

// Charge recurrente d'une agence : eau, electricite, loyer, masse salariale, internet...
// Sert de configuration : chaque mois, l'utilisateur enregistre un paiement (Expense)
// rattache a la charge via Expense.agencyChargeId + Expense.period (YYYY-MM).
// La charge elle-meme est mutable (montant et echeance peuvent evoluer) ; les paiements
// passent par le ledger immuable Expense (regle finance).
model AgencyCharge {
  id               String     @id @default(uuid())
  agencyId         String
  type             ChargeType
  label            String
  defaultAmount    Decimal    @db.Decimal(15, 2)
  // jour du mois ou la charge est due (1-31). Optionnel.
  dueDayOfMonth    Int?
  // commentaire ou reference (n compteur eau, contrat de bail, ...)
  reference        String?
  // Indique que le montant n'est pas fixe (ex: facture d'eau, electricite).
  // L'UI propose de saisir un montant a chaque paiement plutot que de prefiller
  // avec defaultAmount. Pour le calcul de "charges dues", on prend max(defaultAmount, 0).
  isAmountFlexible Boolean    @default(false)
  // Charge auto-geree par le systeme (ex : masse salariale = somme des salaires).
  // Si true, l'utilisateur ne peut pas modifier defaultAmount manuellement ;
  // le serveur recalcule le montant a chaque ajout/MAJ d'employe.
  isAutoManaged    Boolean    @default(false)
  isActive         Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  agency    Agency                 @relation(fields: [agencyId], references: [id])
  expenses  Expense[]
  documents AgencyChargeDocument[]
  history   AgencyChargeHistory[]

  // Une seule charge auto-geree par agence et par type (ex: une seule SALARY auto)
  @@unique([agencyId, type, isAutoManaged])
  @@index([agencyId])
  @@index([type])
  @@map("agency_charges")
}

// Documents attaches a une charge (factures, contrats, releves, ...).
// Ces documents servent de justificatifs et peuvent etre uploades a la creation
// ou ajoutes ulterieurement (ex: facture d'eau du mois).
model AgencyChargeDocument {
  id          String   @id @default(uuid())
  chargeId    String
  url         String
  // Cle MinIO pour pouvoir supprimer / re-uploader. Optionnel pour les liens externes.
  storageKey  String?
  fileName    String?
  contentType String?
  size        Int?
  caption     String?
  uploadedBy  String?
  createdAt   DateTime @default(now())

  charge   AgencyCharge @relation(fields: [chargeId], references: [id], onDelete: Cascade)
  uploader User?        @relation("ChargeDocUploader", fields: [uploadedBy], references: [id])

  @@index([chargeId])
  @@map("agency_charge_documents")
}

// Audit log des modifications d'une charge (creation, MAJ champs, paiements,
// activation/desactivation). Sert d'historique pour la consultation utilisateur.
model AgencyChargeHistory {
  id        String   @id @default(uuid())
  chargeId  String
  action    String // CREATED, UPDATED, PAID, DEACTIVATED, REACTIVATED, DOCUMENT_ADDED, ...
  // Snapshot des champs modifies (avant / apres) ou metadonnees (montant paye, periode...).
  changes   Json?
  comment   String?
  userId    String?
  createdAt DateTime @default(now())

  charge AgencyCharge @relation(fields: [chargeId], references: [id], onDelete: Cascade)
  user   User?        @relation("ChargeHistoryUser", fields: [userId], references: [id])

  @@index([chargeId])
  @@index([action])
  @@map("agency_charge_history")
}

enum ChargeType {
  WATER
  ELECTRICITY
  RENT
  SALARY
  INTERNET
  PHONE
  CLEANING
  SECURITY
  MAINTENANCE
  OTHER
}

// ============================================================
// MAGASINS / ENTREPOTS
// ============================================================

model Warehouse {
  id               String   @id @default(uuid())
  agencyId         String
  name             String
  location         String
  // Frais de magasinage : appliques uniquement aux colis issus d'un conteneur
  // qui restent au-dela de `storageFreeDays`. Tarif journalier en devise de base.
  storageFreeDays  Int      @default(7)
  storageDailyRate Decimal  @default(0) @db.Decimal(15, 2)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  agency          Agency               @relation(fields: [agencyId], references: [id])
  parcels         Parcel[]             @relation("CurrentWarehouse")
  originalParcels Parcel[]             @relation("OriginalWarehouse")
  inventories     WarehouseInventory[]
  spaces          WarehouseSpace[]

  @@index([agencyId])
  @@map("warehouses")
}

// Espace de rangement physique dans un magasin (ex : "Allee A", "Etagere 3").
// Permet une recherche physique rapide d'un colis dans un grand magasin.
model WarehouseSpace {
  id          String   @id @default(uuid())
  warehouseId String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  parcels   Parcel[]  @relation("ParcelSpace")

  @@unique([warehouseId, name])
  @@index([warehouseId])
  @@map("warehouse_spaces")
}

// Inventaire d'un magasin : declenche par un operateur, on scanne les colis
// presents physiquement, puis on cloture pour reconcilier avec le stock theorique.
model WarehouseInventory {
  id          String                   @id @default(uuid())
  warehouseId String
  status      WarehouseInventoryStatus @default(IN_PROGRESS)
  startedById String?
  closedById  String?
  startedAt   DateTime                 @default(now())
  closedAt    DateTime?
  comment     String?

  warehouse Warehouse                @relation(fields: [warehouseId], references: [id])
  startedBy User?                    @relation("InventoryStartedBy", fields: [startedById], references: [id])
  closedBy  User?                    @relation("InventoryClosedBy", fields: [closedById], references: [id])
  items     WarehouseInventoryItem[]

  @@index([warehouseId])
  @@index([status])
  @@map("warehouse_inventories")
}

enum WarehouseInventoryStatus {
  IN_PROGRESS
  CLOSED
  CANCELLED
}

// Une ligne par colis scanne / detecte pendant l'inventaire.
// expected = colis dans le stock theorique au moment du demarrage
// scanned  = a-t-il ete vu pendant l'inventaire
model WarehouseInventoryItem {
  id             String    @id @default(uuid())
  inventoryId    String
  parcelId       String
  expected       Boolean   @default(true)
  scanned        Boolean   @default(false)
  scannedAt      DateTime?
  scannedById    String?
  // True si le colis a ete marque present manuellement (sans scan).
  // Utile pour distinguer le check physique camera-confirm vs cocher a la main.
  markedManually Boolean   @default(false)
  // Observation libre laissee au moment du marquage (ex : "emballage abime",
  // "client present", "manque etiquette").
  observation    String?
  comment        String?

  inventory WarehouseInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  parcel    Parcel             @relation(fields: [parcelId], references: [id])
  scannedBy User?              @relation("InventoryItemScannedBy", fields: [scannedById], references: [id])

  @@unique([inventoryId, parcelId])
  @@index([inventoryId])
  @@index([parcelId])
  @@map("warehouse_inventory_items")
}

// ============================================================
// UTILISATEURS
// ============================================================

model User {
  id               String    @id @default(uuid())
  organizationId   String
  email            String    @unique
  passwordHash     String
  firstName        String
  lastName         String
  phone            String?
  avatarUrl        String?
  role             UserRole  @default(AGENT)
  isActive         Boolean   @default(true)
  isVerified       Boolean   @default(false)
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  userAgencies            UserAgency[]
  responsibleAgencies     Agency[]                      @relation("AgencyResponsible")
  refreshTokens           RefreshToken[]
  paymentsReceived        Payment[]
  voidedPayments          Payment[]                     @relation("VoidedByUser")
  disbursementsIssued     DisbursementVoucher[]         @relation("IssuedByUser")
  disbursementsApproved   DisbursementVoucher[]         @relation("ApprovedByUser")
  transfersInitiated      FundTransfer[]                @relation("InitiatedByUser")
  transfersConfirmed      FundTransfer[]                @relation("ConfirmedByUser")
  closedCashRegisters     AgencyCashRegister[]
  journalEntriesCreated   JournalEntry[]
  expensesApproved        Expense[]
  parcelHistories         ParcelHistory[]
  containerHistories      ContainerHistory[]
  auditLogs               AuditLog[]
  chatMessagesAgent       ChatMessage[]
  assignedConversations   ChatConversation[]
  inventoriesStarted      WarehouseInventory[]          @relation("InventoryStartedBy")
  inventoriesClosed       WarehouseInventory[]          @relation("InventoryClosedBy")
  inventoryItemsScanned   WarehouseInventoryItem[]      @relation("InventoryItemScannedBy")
  chargeDocsUploaded      AgencyChargeDocument[]        @relation("ChargeDocUploader")
  chargeHistoryActions    AgencyChargeHistory[]         @relation("ChargeHistoryUser")
  dailyReportsClosed      AgencyDailyReport[]           @relation("DailyReportClosedBy")
  dailyReportAttachments  AgencyDailyReportAttachment[] @relation("DailyReportAttachmentBy")
  // Lien optionnel 1-1 avec un Employee (pour la connexion personnel/chef d'agence)
  employee                Employee?                     @relation("EmployeeUser")
  salaryDeductionsCreated SalaryDeduction[]             @relation("SalaryDeductionCreator")
  attendancesMarked       Attendance[]                  @relation("AttendanceMarker")
  leavesValidated         EmployeeLeave[]               @relation("LeaveValidator")
  leavesRequested         EmployeeLeave[]               @relation("LeaveRequester")
  sanctionsDecided        EmployeeSanction[]            @relation("SanctionDecider")
  terminationsDecided     ContractTermination[]         @relation("TerminationDecider")
  reviewsAuthored         EmployeeReview[]              @relation("ReviewAuthor")
  passwordResetTokens     PasswordResetToken[]
  permissionOverrides     UserPermissionOverride[]
  justificationsSubmitted AttendanceJustification[]     @relation("JustificationSubmitter")
  justificationsReviewed  AttendanceJustification[]     @relation("JustificationReviewer")
  leavesEnded             EmployeeLeave[]               @relation("LeaveEndedBy")

  @@index([organizationId])
  @@index([email])
  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  AGENT
  COMPTABLE
  MAGASINIER
  SUPERVISEUR
  // Chef d'une agence : peut gerer le personnel de son agence (validations conges,
  // sanctions, pointage). Hierarchiquement au-dessus des PERSONNEL d'une meme agence.
  CHEF_AGENCE
  // Employe simple : se connecte pour pointer, demander conges, voir son profil.
  PERSONNEL
}

model UserAgency {
  userId   String
  agencyId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@id([userId, agencyId])
  @@map("user_agencies")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// Token de reinitialisation de mot de passe (envoye par email).
// Token aleatoire opaque, valable 1h, usage unique (consommé apres utilisation).
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("password_reset_tokens")
}

// ============================================================
// EMPLOYES
// ============================================================

model Employee {
  id                String               @id @default(uuid())
  agencyId          String
  fullName          String
  idNumber          String?
  phone             String?
  // Libelle libre du poste (legacy : conserve pour compat). La verite metier
  // passe progressivement par positionId (FK vers Position) ; ce champ reste
  // synchro pour l'affichage rapide et la retro-compatibilite.
  position          String
  // FK vers la table Position (ABAC). Nullable le temps de la migration des
  // donnees existantes ; les nouveaux Employee doivent renseigner positionId.
  positionId        String?
  // Lien 1-1 vers le profil Client correspondant (un personnel est aussi un
  // potentiel client). Rempli automatiquement par CreateEmployeeUseCase.
  clientId          String?              @unique
  // Override du planning RH pour cet employe. NULL = herite du planning agence
  // (Agency.workScheduleId). Permet d'eviter les doublons quand le personnel
  // suit l'horaire standard.
  scheduleId        String?
  level             String?
  // Niveau d'etudes (ex : Licence, Master, BAC+3, ...) et specialite (ex : Logistique, Comptabilite)
  educationLevel    String?
  specialty         String?
  baseSalary        Decimal              @default(0) @db.Decimal(15, 2)
  startDate         DateTime             @default(now())
  endDate           DateTime?
  // Photos employe : selfie (visage), plan (localisation domicile),
  // document d'identification (CNI, passeport...).
  // idDocumentBack* pour le verso (CNI a 2 faces, passeport peut avoir page d'identification recto/verso).
  selfieUrl         String?
  selfieKey         String?
  locationPlanUrl   String?
  locationPlanKey   String?
  idDocumentUrl     String?
  idDocumentKey     String?
  idDocumentBackUrl String?
  idDocumentBackKey String?
  // Type de contrat
  contractType      EmployeeContractType @default(CDI)
  // Superieur hierarchique direct (FK self vers Employee)
  managerId         String?
  // Lien optionnel vers User pour permettre la connexion de l'employe sur la plateforme
  // (role PERSONNEL ou CHEF_AGENCE). Un meme User <-> 1 Employee.
  userId            String?              @unique
  // Marqueur "chef d'agence" (utilise pour validation hierarchique meme si role User est PERSONNEL).
  // Permet de promouvoir un employe en chef sans toucher au User.
  isAgencyManager   Boolean              @default(false)
  isActive          Boolean              @default(true)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  agency            Agency                     @relation(fields: [agencyId], references: [id])
  manager           Employee?                  @relation("EmployeeManager", fields: [managerId], references: [id])
  reports           Employee[]                 @relation("EmployeeManager")
  user              User?                      @relation("EmployeeUser", fields: [userId], references: [id])
  positionRef       Position?                  @relation(fields: [positionId], references: [id])
  client            Client?                    @relation("EmployeeClient", fields: [clientId], references: [id])
  schedule          WorkSchedule?              @relation("EmployeeSchedule", fields: [scheduleId], references: [id])
  agencyAssignments EmployeeAgencyAssignment[]
  holidays          Holiday[]                  @relation("EmployeeHoliday")
  payslips          Payslip[]
  documents         EmployeeDocument[]
  deductions        SalaryDeduction[]
  shifts            EmployeeShift[]
  attendances       Attendance[]
  leaves            EmployeeLeave[]
  sanctions         EmployeeSanction[]
  termination       ContractTermination?
  reviews           EmployeeReview[]

  @@index([agencyId])
  @@index([managerId])
  @@index([positionId])
  @@index([clientId])
  @@map("employees")
}

enum EmployeeContractType {
  STAGIAIRE
  CDD
  CDI
  PRESTATAIRE
}

// Documents joints au profil d'un employe : diplomes, contrats, certificats, etc.
// Multi-fichiers et types varies (image, PDF, ...).
model EmployeeDocument {
  id          String               @id @default(uuid())
  employeeId  String
  type        EmployeeDocumentType
  label       String
  url         String
  storageKey  String?
  contentType String?
  size        Int?
  // Date de validite optionnelle (ex: certificat medical valable 1 an)
  validUntil  DateTime?
  uploadedBy  String?
  createdAt   DateTime             @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([type])
  @@map("employee_documents")
}

enum EmployeeDocumentType {
  DIPLOMA
  CV
  CONTRACT
  ID_DOCUMENT
  CERTIFICATE
  OTHER
}

// Retenue ponctuelle sur salaire avec motif et historisation.
// Appliquee une seule fois lors du prochain paiement (ou paiement choisi).
// Quand `appliedToExpenseId` est rempli, la retenue est consommee.
model SalaryDeduction {
  id                 String                @id @default(uuid())
  employeeId         String
  amount             Decimal               @db.Decimal(15, 2)
  reason             String
  // Periode (YYYY-MM) cible si l'utilisateur veut limiter a un mois donne
  period             String?
  // Statut : PENDING -> APPLIED -> CANCELLED
  status             SalaryDeductionStatus @default(PENDING)
  // Lien vers l'Expense / Payslip qui a deduit cette retenue (immuable)
  appliedToExpenseId String?
  appliedToPayslipId String?
  createdById        String?
  cancelledReason    String?
  createdAt          DateTime              @default(now())
  appliedAt          DateTime?
  cancelledAt        DateTime?

  employee  Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy User?    @relation("SalaryDeductionCreator", fields: [createdById], references: [id])

  @@index([employeeId])
  @@index([status])
  @@map("salary_deductions")
}

enum SalaryDeductionStatus {
  PENDING
  APPLIED
  CANCELLED
}

// ============================================================
// PLANNING / POINTAGE / RH
// ============================================================

// Planning hebdomadaire recurrent d'un employe.
// dayOfWeek 0..6 (dimanche..samedi). Plusieurs creneaux possibles par jour.
model EmployeeShift {
  id         String   @id @default(uuid())
  employeeId String
  dayOfWeek  Int
  // HH:mm 24h
  startTime  String
  endTime    String
  // Si false : repos (pas de service ce jour). Surcharge le planning agence.
  isWorking  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([employeeId, dayOfWeek])
  @@map("employee_shifts")
}

// Pointage : 1 ligne par employe et par jour.
// Marque par un superviseur (chef d'agence, admin).
model Attendance {
  id                    String           @id @default(uuid())
  employeeId            String
  date                  DateTime         @db.Date
  status                AttendanceStatus
  // Heure d'arrivee (si LATE/PRESENT) en HH:mm
  checkInTime           String?
  // Heure de depart (optionnelle)
  checkOutTime          String?
  // Heures attendues du jour (snapshot du planning au moment du pointage), HH:mm.
  // Permet de comparer meme si le planning evolue ulterieurement.
  expectedStart         String?
  expectedEnd           String?
  // Minutes de retard (max(0, checkIn - expectedStart))
  lateMinutes           Int?
  // Minutes de depart anticipe (max(0, expectedEnd - checkOut))
  earlyDepartureMinutes Int?
  // Heures supplementaires (max(0, checkOut - expectedEnd) + max(0, expectedStart - checkIn) si arrivee anticipee compte)
  overtimeMinutes       Int?
  // Heures manquantes (lateMinutes + earlyDepartureMinutes), denormalise pour les stats.
  undertimeMinutes      Int?
  // Pauses du jour en minutes (deduites des heures payables).
  breakMinutes          Int?             @default(0)
  // Motif libre (raison absence/retard)
  reason                String?
  // Note libre additionnelle
  note                  String?
  // Auto = marque par cron de fin de journee (si aucun pointage), Manual sinon
  source                AttendanceSource @default(MANUAL)
  markedByUserId        String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  employee       Employee                  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  markedBy       User?                     @relation("AttendanceMarker", fields: [markedByUserId], references: [id])
  justifications AttendanceJustification[]

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
  @@index([status])
  @@map("attendances")
}

// Justification d'une absence ou d'un retard. Une Attendance peut avoir
// plusieurs tentatives de justification (ex: rejetee puis re-soumise).
// La justification "active" est la plus recente avec status APPROVED ou PENDING.
model AttendanceJustification {
  id                String                        @id @default(uuid())
  attendanceId      String
  // Auteur de la soumission : employe lui-meme (via portail) ou superviseur.
  submittedByUserId String?
  text              String
  status            AttendanceJustificationStatus @default(PENDING)
  reviewedByUserId  String?
  reviewComment     String?
  reviewedAt        DateTime?
  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt

  attendance  Attendance                          @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  submittedBy User?                               @relation("JustificationSubmitter", fields: [submittedByUserId], references: [id])
  reviewedBy  User?                               @relation("JustificationReviewer", fields: [reviewedByUserId], references: [id])
  attachments AttendanceJustificationAttachment[]

  @@index([attendanceId])
  @@index([status])
  @@map("attendance_justifications")
}

enum AttendanceJustificationStatus {
  PENDING
  APPROVED
  REJECTED
}

// Pieces jointes d'une justification : image (selfie, photo certificat) ou
// document (PDF certificat medical, convocation, ...).
model AttendanceJustificationAttachment {
  id              String   @id @default(uuid())
  justificationId String
  url             String
  storageKey      String?
  fileName        String?
  contentType     String?
  size            Int?
  caption         String?
  createdAt       DateTime @default(now())

  justification AttendanceJustification @relation(fields: [justificationId], references: [id], onDelete: Cascade)

  @@index([justificationId])
  @@map("attendance_justification_attachments")
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  ON_LEAVE
  HOLIDAY
}

enum AttendanceSource {
  MANUAL
  AUTO
}

// Demande de conges : workflow pending -> approved/rejected par chef/admin.
model EmployeeLeave {
  id                String              @id @default(uuid())
  employeeId        String
  type              EmployeeLeaveType
  fromDate          DateTime            @db.Date
  toDate            DateTime            @db.Date
  reason            String?
  status            EmployeeLeaveStatus @default(PENDING)
  validatedByUserId String?
  validationComment String?
  validatedAt       DateTime?
  // Demandeur : peut etre l'employe lui-meme (via portail) ou un superviseur qui le declare
  requestedByUserId String?
  // Cloture anticipee : si renseigne, le conge prend fin a cette date (incluse)
  // au lieu de toDate. Permet a l'employe ou au superviseur de mettre fin avant
  // le terme. status passe a ENDED_EARLY.
  endedEarlyAt      DateTime?           @db.Date
  endedByUserId     String?
  endReason         String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  validatedBy User?    @relation("LeaveValidator", fields: [validatedByUserId], references: [id])
  requestedBy User?    @relation("LeaveRequester", fields: [requestedByUserId], references: [id])
  endedBy     User?    @relation("LeaveEndedBy", fields: [endedByUserId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([fromDate, toDate])
  @@map("employee_leaves")
}

enum EmployeeLeaveType {
  PAID
  UNPAID
  SICK
  MATERNITY
  PATERNITY
  EXCEPTIONAL
}

enum EmployeeLeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  // Cloture avant la toDate prevue (par l'employe ou un superviseur).
  ENDED_EARLY
}

// Sanctions disciplinaires : avertissement, mise a pied (avec duree), licenciement.
model EmployeeSanction {
  id              String               @id @default(uuid())
  employeeId      String
  type            EmployeeSanctionType
  reason          String
  // Date d'effet (debut)
  effectiveFrom   DateTime
  // Date de fin (mise a pied avec duree). Null pour avertissement / licenciement.
  effectiveTo     DateTime?
  // User qui a decide (chef d'agence, admin)
  decidedByUserId String?
  // Documents joints (PV, courrier, ...)
  attachmentUrl   String?
  attachmentKey   String?
  createdAt       DateTime             @default(now())

  employee  Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  decidedBy User?    @relation("SanctionDecider", fields: [decidedByUserId], references: [id])

  @@index([employeeId])
  @@index([type])
  @@map("employee_sanctions")
}

enum EmployeeSanctionType {
  WARNING
  SUSPENSION
  PAY_FREEZE
  DEMOTION
}

// Rupture de contrat : demission, licenciement, fin CDD, ...
// Quand crée, cela passe Employee.isActive a false et set Employee.endDate.
model ContractTermination {
  id              String                  @id @default(uuid())
  employeeId      String                  @unique
  type            ContractTerminationType
  reason          String
  effectiveDate   DateTime                @db.Date
  decidedByUserId String?
  // Documents joints (lettre de demission, lettre de licenciement, ...)
  attachmentUrl   String?
  attachmentKey   String?
  createdAt       DateTime                @default(now())

  employee  Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  decidedBy User?    @relation("TerminationDecider", fields: [decidedByUserId], references: [id])

  @@index([employeeId])
  @@map("contract_terminations")
}

enum ContractTerminationType {
  RESIGNATION // demission
  DISMISSAL // licenciement
  END_OF_CONTRACT // fin CDD/stage
  MUTUAL_AGREEMENT // rupture conventionnelle
  RETIREMENT
  OTHER
}

// Evaluation periodique : configurable par agence (criteres) ; on garde un payload JSON
// flexible pour eviter d'imposer un format rigide.
model EmployeeReview {
  id             String   @id @default(uuid())
  employeeId     String
  // Periode evaluee : libellé libre (ex : "Q1-2026", "2026-04", "Annuel 2025")
  period         String
  // Note globale optionnelle (ex : 0..20 ou 0..100)
  score          Decimal? @db.Decimal(5, 2)
  // Synthese textuelle libre
  summary        String?
  // Criteres notes : Json { critereName: { score, comment } }
  criteria       Json?
  reviewerUserId String?
  createdAt      DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  reviewer User?    @relation("ReviewAuthor", fields: [reviewerUserId], references: [id])

  @@index([employeeId])
  @@index([period])
  @@map("employee_reviews")
}

// Configuration de la grille d'evaluation par agence (criteres)
model AgencyReviewConfig {
  id        String   @id @default(uuid())
  agencyId  String   @unique
  // Liste de criteres. Json [{ key, label, max }]
  criteria  Json
  // "MONTHLY" / "QUARTERLY" / "YEARLY"
  cadence   String   @default("QUARTERLY")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  agency Agency @relation("AgencyReviewConfig", fields: [agencyId], references: [id], onDelete: Cascade)

  @@map("agency_review_configs")
}

model Payslip {
  id                  String    @id @default(uuid())
  employeeId          String
  period              String
  baseSalary          Decimal   @db.Decimal(15, 2)
  bonuses             Decimal   @default(0) @db.Decimal(15, 2)
  benefitsInKind      Decimal   @default(0) @db.Decimal(15, 2)
  socialContributions Decimal   @default(0) @db.Decimal(15, 2)
  grossSalary         Decimal   @db.Decimal(15, 2)
  netSalary           Decimal   @db.Decimal(15, 2)
  isPaid              Boolean   @default(false)
  // Date effective du paiement (nul tant que isPaid=false). Mise a jour
  // lorsqu'on declenche PayEmployeeFromCashRegisterUseCase.
  paidAt              DateTime?
  // Reference vers l'Expense de paiement (immutable). Permet de remonter
  // depuis le payslip vers la caisse qui a ete debitee.
  paidExpenseId       String?   @unique

  // Note libre saisie au paiement (motif, contexte, ...).
  paymentNote     String?
  // Total des retenues effectivement appliquees au moment du paiement (resume).
  deductionsTotal Decimal? @db.Decimal(15, 2)

  generatedAt DateTime @default(now())

  employee    Employee @relation(fields: [employeeId], references: [id])
  paidExpense Expense? @relation("PayslipPaidExpense", fields: [paidExpenseId], references: [id])

  @@index([employeeId])
  @@map("payslips")
}

// ============================================================
// CLIENTS
// ============================================================

model Client {
  id                String      @id @default(uuid())
  organizationId    String
  agencyId          String
  fullName          String
  phone             String      @unique
  email             String?
  idNumber          String?
  imageUrl          String?
  imageKey          String?
  // Photos document d'identification recto + verso. Servent au moment du
  // retrait d'un colis pour que l'agent confronte la personne en face avec
  // la photo et valide la remise.
  idDocumentUrl     String?
  idDocumentKey     String?
  idDocumentBackUrl String?
  idDocumentBackKey String?
  address           String?
  clientType        ClientType  @default(INDIVIDUAL)
  loyaltyTier       LoyaltyTier @default(STANDARD)
  loyaltyPoints     Int         @default(0)
  totalSpent        Decimal     @default(0) @db.Decimal(15, 2)
  isActive          Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Auth fields for client portal
  passwordHash   String?
  isPortalActive Boolean @default(false)

  organization        Organization[]
  agency              Agency               @relation(fields: [agencyId], references: [id])
  parcels             Parcel[]             @relation("ParcelClient")
  parcelsAsRecipient  Parcel[]             @relation("ParcelRecipient")
  invoices            Invoice[]
  debts               Debt[]
  loyaltyTransactions LoyaltyTransaction[]
  penalties           Penalty[]
  chatConversations   ChatConversation[]
  notifications       Notification[]       @relation("ClientNotifications")
  partnerPricings     PartnerPricing[]
  parcelGroups        ParcelGroup[]        @relation("ClientParcelGroups")
  // Lien retour 1-1 si ce client correspond a un membre du personnel.
  employee            Employee?            @relation("EmployeeClient")

  @@index([organizationId])
  @@index([agencyId])
  @@index([phone])
  @@index([clientType])
  @@map("clients")
}

enum ClientType {
  INDIVIDUAL
  COMPANY
  PARTNER
}

enum LoyaltyTier {
  STANDARD
  SILVER
  GOLD
  VIP
}

// Tarification specifique par partenaire (override des prix de la TransitRoute)
model PartnerPricing {
  id             String   @id @default(uuid())
  clientId       String
  transitRouteId String?
  pricePerKg     Decimal  @db.Decimal(15, 2)
  pricePerVolume Decimal  @default(0) @db.Decimal(15, 2)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  transitRoute TransitRoute? @relation(fields: [transitRouteId], references: [id])

  @@unique([clientId, transitRouteId])
  @@index([clientId])
  @@map("partner_pricings")
}

// NOTE : ancien modele Recipient fusionne dans Client.
// Un client peut maintenant etre a la fois expediteur (Parcel.client) et
// destinataire (Parcel.recipient via la meme table). Les anciens recipients
// ont ete migres en Client (cf. migration *_merge_recipients_into_clients).

// ============================================================
// ROUTES DE TRANSIT
// ============================================================

model TransitRoute {
  id                    String      @id @default(uuid())
  organizationId        String
  name                  String
  type                  TransitType
  departureCity         String
  departureCountry      String
  arrivalCity           String
  arrivalCountry        String
  pricePerKg            Decimal     @db.Decimal(15, 2)
  pricePerVolume        Decimal     @default(0) @db.Decimal(15, 2)
  estimatedDurationDays Int         @default(0)
  isActive              Boolean     @default(true)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id])
  parcels         Parcel[]
  containers      Container[]
  partnerPricings PartnerPricing[]

  @@index([organizationId])
  @@map("transit_routes")
}

enum TransitType {
  AIR
  SEA
  LAND
}

// ============================================================
// CONTENEURS
// ============================================================

model Container {
  id                   String          @id @default(uuid())
  // organizationId pour isolation multi-tenant
  organizationId       String
  designation          String
  type                 TransitType
  isForwarding         Boolean         @default(false)
  // Hierarchie : un conteneur d'acheminement (isForwarding=true) peut etre place
  // dans un conteneur parent AIR/SEA. Le parent ne peut pas etre lui-meme forwarding.
  parentContainerId    String?
  // Transporteur (facultatif) : nom/reference de la compagnie/personne en charge.
  carrier              String?
  capacity             Decimal         @db.Decimal(15, 2)
  // currentLoad : valeur snapshot, peut driver. Repository la recalcule a la lecture.
  currentLoad          Decimal         @default(0) @db.Decimal(15, 2)
  transitRouteId       String?
  departureAgencyId    String
  arrivalAgencyId      String
  status               ContainerStatus @default(EMPTY)
  loadingDate          DateTime?
  departureDate        DateTime?
  estimatedArrivalDate DateTime?
  actualArrivalDate    DateTime?
  isDeleted            Boolean         @default(false)
  deletedAt            DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  transitRoute     TransitRoute?         @relation(fields: [transitRouteId], references: [id])
  departureAgency  Agency                @relation("DepartureAgency", fields: [departureAgencyId], references: [id])
  arrivalAgency    Agency                @relation("ArrivalAgency", fields: [arrivalAgencyId], references: [id])
  parentContainer  Container?            @relation("ContainerHierarchy", fields: [parentContainerId], references: [id])
  childContainers  Container[]           @relation("ContainerHierarchy")
  parcels          Parcel[]              @relation("CurrentContainer")
  lastContainerFor Parcel[]              @relation("LastContainer")
  histories        ContainerHistory[]
  manifests        ShippingManifest[]
  expenses         Expense[]
  routingSource    InterAgencyRouting[]  @relation("SourceContainer")
  routingTarget    InterAgencyRouting[]  @relation("TargetContainer")
  discrepancies    ManifestDiscrepancy[]

  @@unique([organizationId, designation])
  @@index([organizationId])
  @@index([departureAgencyId])
  @@index([arrivalAgencyId])
  @@index([status])
  @@index([parentContainerId])
  @@map("containers")
}

// Cycle de vie simplifie a 5 statuts (audit fix #3) :
// EMPTY -> LOADING -> IN_TRANSIT -> RECEIVED -> UNLOADED (terminal)
// Les anciens ARRIVED + UNLOADING sont migres vers RECEIVED.
enum ContainerStatus {
  EMPTY
  LOADING
  IN_TRANSIT
  RECEIVED
  UNLOADED
}

// ============================================================
// COLIS
// ============================================================

model Parcel {
  id                  String       @id @default(uuid())
  // organizationId : isolation multi-tenant
  organizationId      String
  trackingNumber      String       @unique
  // trackingFournisseur : code/numero de suivi communique par le fournisseur
  // (ex: code Aliexpress, DHL externe). Optionnel, non unique cote DB pour
  // tolerer les doublons saisis par erreur ; l'unicite metier est laissee
  // a l'utilisateur.
  trackingFournisseur String?
  designation         String
  weight              Decimal?     @db.Decimal(15, 3)
  originalWeight      Decimal?     @db.Decimal(15, 3)
  volume              Decimal?     @db.Decimal(15, 3)
  imageUrl            String?
  qrCodeUrl           String?
  origin              String?
  // Destination structuree (audit fix #1) :
  // - destination = ville d'arrivee (legacy / pre-rempli depuis transitRoute.arrivalCity)
  // - destinationAgencyId = agence physique de reception (peut etre NULL si livraison directe)
  // - destinationAddress = adresse precise libre (rue, quartier)
  destination         String
  destinationAgencyId String?
  destinationAddress  String?
  observation         String?
  originalObservation String?
  status              ParcelStatus @default(IN_STOCK)
  isPresent           Boolean      @default(true)
  price               Decimal      @default(0) @db.Decimal(15, 2)

  // Categorie + flags metiers (audit fix #10)
  category      ParcelCategory @default(STANDARD)
  isFragile     Boolean        @default(false)
  isHazardous   Boolean        @default(false)
  declaredValue Decimal?       @db.Decimal(15, 2) // pour assurance

  clientId            String
  recipientId         String?
  warehouseId         String?
  originalWarehouseId String?
  // Espace de rangement physique dans le magasin courant (recherche rapide)
  spaceId             String?
  // Lien optionnel vers un ParcelGroup (envoi groupe par un client)
  parcelGroupId       String?
  containerId         String?
  lastContainerId     String?
  transitRouteId      String?
  // invoiceId : NON unique. Une facture peut couvrir N colis (audit fix #5).
  invoiceId           String?

  arrivalDate        DateTime?
  pickupDate         DateTime?
  penaltyStartDate   DateTime?
  warehouseEnteredAt DateTime?

  isDeleted        Boolean   @default(false)
  deletedAt        DateTime?
  // Archivage : different de la suppression (qui est un soft-delete metier).
  // Un colis archive est masque de tous les listings/recherches/exports par
  // defaut, mais reste accessible via l'onglet "Archives" pour desarchivage.
  isArchived       Boolean   @default(false)
  archivedAt       DateTime?
  archivedByUserId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  client            Client          @relation("ParcelClient", fields: [clientId], references: [id])
  recipient         Client?         @relation("ParcelRecipient", fields: [recipientId], references: [id])
  warehouse         Warehouse?      @relation("CurrentWarehouse", fields: [warehouseId], references: [id])
  originalWarehouse Warehouse?      @relation("OriginalWarehouse", fields: [originalWarehouseId], references: [id])
  space             WarehouseSpace? @relation("ParcelSpace", fields: [spaceId], references: [id])
  parcelGroup       ParcelGroup?    @relation(fields: [parcelGroupId], references: [id])
  destinationAgency Agency?         @relation("ParcelDestinationAgency", fields: [destinationAgencyId], references: [id])
  container         Container?      @relation("CurrentContainer", fields: [containerId], references: [id])
  lastContainer     Container?      @relation("LastContainer", fields: [lastContainerId], references: [id])
  transitRoute      TransitRoute?   @relation(fields: [transitRouteId], references: [id])
  invoice           Invoice?        @relation(fields: [invoiceId], references: [id])

  histories      ParcelHistory[]
  manifestLines  ManifestLine[]
  penalties      Penalty[]
  routings       InterAgencyRouting[]
  images         ParcelImage[]
  discrepancies  ManifestDiscrepancy[]
  inventoryItems WarehouseInventoryItem[]

  @@index([organizationId])
  @@index([clientId])
  @@index([warehouseId])
  @@index([spaceId])
  @@index([parcelGroupId])
  @@index([containerId])
  @@index([lastContainerId])
  @@index([destinationAgencyId])
  @@index([invoiceId])
  @@index([status])
  @@index([trackingNumber])
  @@index([category])
  @@index([trackingFournisseur])
  // Index pour filtrer rapidement les colis archives (utilise dans tous les
  // listings : par defaut on exclut les archives).
  @@index([isArchived])
  @@map("parcels")
}

// Categorie metier du colis (audit fix #10)
enum ParcelCategory {
  STANDARD
  DOCUMENT
  FOOD
  ELECTRONICS
  CLOTHING
  OTHER
}

// Galerie d'images d'un colis (multi-images)
model ParcelImage {
  id        String   @id @default(uuid())
  parcelId  String
  url       String
  caption   String?
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  parcel Parcel @relation(fields: [parcelId], references: [id], onDelete: Cascade)

  @@index([parcelId])
  @@map("parcel_images")
}

enum ParcelStatus {
  IN_STOCK
  LOADING
  IN_TRANSIT
  ARRIVED
  RECEIVED
  DELIVERED
  LOST
}

// ============================================================
// ROUTAGE INTER-AGENCES
// ============================================================

model InterAgencyRouting {
  id                String        @id @default(uuid())
  sourceContainerId String
  targetContainerId String?
  parcelId          String
  sourceAgencyId    String
  targetAgencyId    String
  targetCity        String
  routingStatus     RoutingStatus @default(PENDING)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  sourceContainer Container  @relation("SourceContainer", fields: [sourceContainerId], references: [id])
  targetContainer Container? @relation("TargetContainer", fields: [targetContainerId], references: [id])
  parcel          Parcel     @relation(fields: [parcelId], references: [id])

  @@index([sourceContainerId])
  @@index([parcelId])
  @@map("inter_agency_routings")
}

enum RoutingStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
}

// ============================================================
// FACTURATION
// ============================================================

model Invoice {
  id          String        @id @default(uuid())
  reference   String        @unique
  clientId    String
  agencyId    String
  totalAmount Decimal       @db.Decimal(15, 2)
  discount    Decimal       @default(0) @db.Decimal(15, 2)
  tva         Decimal       @default(0) @db.Decimal(15, 2)
  netAmount   Decimal       @db.Decimal(15, 2)
  paidAmount  Decimal       @default(0) @db.Decimal(15, 2)
  balance     Decimal       @db.Decimal(15, 2)
  currency    String        @default("XAF")
  status      InvoiceStatus @default(UNPAID)
  dueDate     DateTime?
  issuedAt    DateTime      @default(now())
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Lien optionnel vers un ParcelGroup : la facture est globale pour le groupe.
  parcelGroupId String? @unique

  client      Client       @relation(fields: [clientId], references: [id])
  agency      Agency       @relation(fields: [agencyId], references: [id])
  // 1 facture peut couvrir N colis (audit fix #5)
  parcels     Parcel[]
  payments    Payment[]
  debts       Debt[]
  parcelGroup ParcelGroup? @relation(fields: [parcelGroupId], references: [id])

  @@index([clientId])
  @@index([agencyId])
  @@index([status])
  @@map("invoices")
}

// Groupe de colis envoye en lot par un client. Permet d'avoir une seule
// facture globale pour N colis. Chaque colis garde son propre tracking.
model ParcelGroup {
  id             String            @id @default(uuid())
  organizationId String
  clientId       String
  agencyId       String
  reference      String            @unique
  label          String?
  notes          String?
  status         ParcelGroupStatus @default(DRAFT)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  client  Client   @relation("ClientParcelGroups", fields: [clientId], references: [id])
  agency  Agency   @relation(fields: [agencyId], references: [id])
  parcels Parcel[]
  invoice Invoice?

  @@index([clientId])
  @@index([agencyId])
  @@index([status])
  @@map("parcel_groups")
}

enum ParcelGroupStatus {
  DRAFT // en cours de saisie, colis ajoutables
  FINALIZED // facture globale generee, plus de modifications
  SENT // facture envoyee au client
  PAID // facture totalement payee
  CANCELLED
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
  CANCELLED
}

