// ============================================================
// DEPENSES
// ============================================================

model Expense {
  id                       String    @id @default(uuid())
  agencyId                 String
  title                    String
  reason                   String
  description              String?
  category                 String?
  orderer                  String?
  amount                   Decimal   @db.Decimal(15, 2)
  receiptUrl               String?
  justificationUrl         String?
  containerId              String?
  parcelId                 String?
  associationType          String?
  approvedByUserId         String?
  // Lien optionnel vers une charge recurrente (eau, electricite, loyer, ...)
  agencyChargeId           String?
  // Periode de la charge au format YYYY-MM (ex : "2025-11"). Permet de detecter
  // les charges deja payees pour un mois donne (= idempotence metier).
  period                   String?
  // Caisse depuis laquelle le paiement a ete effectue. Permet de remonter
  // depuis l'Expense vers le compte qui a ete debite, et inversement.
  cashRegisterId           String?
  // Caisse siege quand la depense est payee depuis le siege au lieu de
  // l'agence. Mutuellement exclusif avec cashRegisterId (au plus l'un des
  // deux est defini).
  headOfficeCashRegisterId String?
  // Lien 1-1 vers le bon de decaissement genere au moment du paiement
  // de cette depense. Permet de dedupliquer dans les agregations financieres
  // (rapport journalier : profit = recettes - expenses - disbursements_sans_expense).
  // Null pour les depenses non encore payees ou les enregistrements legacy.
  disbursementId           String?   @unique
  // Propagation depense forwarding -> parents : si cette depense est une
  // copie automatique creee depuis une depense forwarding, parentExpenseId
  // pointe sur l'originale (la depense du forwarding). isAutoFromForwarding=
  // true marque les copies pour affichage badge "AUTO" + lien.
  parentExpenseId          String?
  isAutoFromForwarding     Boolean   @default(false)
  // Etat de paiement. Pour compat ascendante : true par defaut (toutes les
  // depenses historiques ont ete creees au moment de leur paiement). Les
  // depenses imputees a un conteneur (CreateContainerExpense) sont creees
  // avec isPaid=false puis payees plus tard via PayContainerExpense.
  isPaid                   Boolean   @default(true)
  paidAt                   DateTime?
  paidByUserId             String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  agency                 Agency                  @relation(fields: [agencyId], references: [id])
  container              Container?              @relation(fields: [containerId], references: [id])
  approvedBy             User?                   @relation(fields: [approvedByUserId], references: [id])
  paidBy                 User?                   @relation("ExpensePaidBy", fields: [paidByUserId], references: [id])
  agencyCharge           AgencyCharge?           @relation(fields: [agencyChargeId], references: [id])
  cashRegister           AgencyCashRegister?     @relation(fields: [cashRegisterId], references: [id])
  headOfficeCashRegister HeadOfficeCashRegister? @relation("HeadOfficeExpense", fields: [headOfficeCashRegisterId], references: [id])
  paidPayslip            Payslip?                @relation("PayslipPaidExpense")
  payslipInstallment     PayslipPayment?         @relation("PayslipInstallmentExpense")
  disbursement           DisbursementVoucher?    @relation("ExpenseDisbursement", fields: [disbursementId], references: [id])
  // Self-relation pour propagation forwarding -> parents.
  parentExpense          Expense?                @relation("ForwardingExpensePropagation", fields: [parentExpenseId], references: [id])
  childExpenses          Expense[]               @relation("ForwardingExpensePropagation")
  // Pieces jointes additionnelles (justificatifs / preuves / images).
  attachments            ExpenseAttachment[]

  @@index([agencyId])
  @@index([agencyChargeId, period])
  @@index([cashRegisterId])
  @@index([headOfficeCashRegisterId])
  @@index([parentExpenseId])
  @@map("expenses")
}

model ExpenseAttachment {
  id               String   @id @default(uuid())
  expenseId        String
  url              String
  key              String
  kind             String // 'IMAGE' | 'PDF' | 'OTHER'
  caption          String?
  uploadedByUserId String?
  createdAt        DateTime @default(now())

  expense    Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  uploadedBy User?   @relation("ExpenseAttachmentUploader", fields: [uploadedByUserId], references: [id])

  @@index([expenseId])
  @@map("expense_attachments")
}

// ============================================================
// DETTES
// ============================================================

// ============================================================
// DETTES - REFONTE TYPEE
// ============================================================
// Une dette peut etre : CLIENT (colis non paye), PERSONNEL (avance salaire),
// AGENCY (charge non reglee), CARRIER (compte transporteur). Le champ `type`
// determine quelle cle etrangere est utilisee (validation cote use case).
// Les modifications sont tracees via DebtHistory ; les paiements via
// DebtPayment. Modification directe du montant interdite : passer par
// AdjustDebtUseCase (admin only) qui ecrit dans DebtHistory.

model Debt {
  id             String   @id @default(uuid())
  // Reference unique generee a la creation (DET-AAAAMMDD-NNNN).
  reference      String   @unique
  // organizationId pour isolation multi-tenant (toutes les dettes sont
  // scopees par organisation).
  organizationId String
  type           DebtType
  // Agence rattachee : pour CLIENT/PERSONNEL c'est l'agence operante ; pour
  // AGENCY c'est l'agence qui doit ; pour CARRIER c'est l'agence emettrice.
  agencyId       String

  // FKs typees -- au moins une est definie selon `type`. La coherence est
  // garantie par CreateDebtUseCase (validation au create).
  clientId       String?
  employeeId     String?
  carrierId      String?
  parcelId       String?
  // Lien optionnel vers une facture (cas dette client adossee a facture
  // partiellement payee au retrait colis).
  invoiceId      String?
  // Charge recurrente (agence) qui a genere la dette (loyer, eau, ...).
  agencyChargeId String?

  // Motif resume (court, recherche). description = long form si besoin.
  motif       String
  description String?
  // Creancier libre si pas de FK adequate (ex: prestataire ponctuel pour
  // dette agence). Persiste pour audit meme apres suppression du tiers.
  creditor    String?

  totalAmount     Decimal @db.Decimal(15, 2)
  paidAmount      Decimal @default(0) @db.Decimal(15, 2)
  // remainingAmount = totalAmount - paidAmount, denormalise pour requetes
  // rapides. Maintenu par RecordDebtPaymentUseCase / AdjustDebtUseCase.
  remainingAmount Decimal @db.Decimal(15, 2)

  // Echeancier : nextDueDate = prochaine echeance, dueDateFinal = echeance
  // finale (tout doit etre paye avant). subDueDates = sous-echeances
  // intermediaires (JSON [{ date, amount, paid }]) pour paiement echelonne.
  nextDueDate  DateTime?
  dueDateFinal DateTime?
  subDueDates  Json?

  // Categorie metier (transport, douane, magasinage, ...). Sert au tri/filtrage
  // dans la vue dettes + a la generation de rapports financiers.
  category  DebtCategory @default(OTHER)
  // Priorite manuelle. Determine l'ordre dans le tableau de suivi et le
  // declencheur des relances (CRITICAL = relance immediate apres echeance).
  priority  DebtPriority @default(MEDIUM)
  status    DebtStatus   @default(ACTIVE)
  isCleared Boolean      @default(false)
  alertSent Boolean      @default(false)

  // Trace : qui a cree, qui a annule (le cas echeant). Annulation est
  // soft : status = CANCELLED, voidReason rempli, mais la ligne reste.
  createdByUserId String?
  voidedAt        DateTime?
  voidReason      String?
  voidedByUserId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id])
  agency       Agency           @relation(fields: [agencyId], references: [id])
  client       Client?          @relation(fields: [clientId], references: [id])
  employee     Employee?        @relation("EmployeeDebts", fields: [employeeId], references: [id])
  carrier      Carrier?         @relation(fields: [carrierId], references: [id])
  parcel       Parcel?          @relation(fields: [parcelId], references: [id])
  invoice      Invoice?         @relation(fields: [invoiceId], references: [id])
  agencyCharge AgencyCharge?    @relation(fields: [agencyChargeId], references: [id])
  createdBy    User?            @relation("DebtCreatedBy", fields: [createdByUserId], references: [id])
  voidedBy     User?            @relation("DebtVoidedBy", fields: [voidedByUserId], references: [id])
  payments     DebtPayment[]
  histories    DebtHistory[]
  attachments  DebtAttachment[]

  @@index([organizationId])
  @@index([agencyId])
  @@index([type])
  @@index([clientId])
  @@index([employeeId])
  @@index([carrierId])
  @@index([parcelId])
  @@index([invoiceId])
  @@index([status])
  @@index([nextDueDate])
  @@map("debts")
}

model DebtAttachment {
  id               String   @id @default(uuid())
  debtId           String
  url              String
  key              String
  kind             String // 'IMAGE' | 'PDF' | 'OTHER'
  caption          String?
  uploadedByUserId String?
  createdAt        DateTime @default(now())

  debt       Debt  @relation(fields: [debtId], references: [id], onDelete: Cascade)
  uploadedBy User? @relation("DebtAttachmentUploader", fields: [uploadedByUserId], references: [id])

  @@index([debtId])
  @@map("debt_attachments")
}

enum DebtType {
  CLIENT // client doit a la societe (colis retire sans paiement, avance partielle)
  EMPLOYEE // societe doit a un employe (avance salaire, remboursement frais)
  AGENCY // societe doit a un tiers (charge agence non reglee : loyer, eau, ...)
  CARRIER // societe doit a un transporteur (compte transporteur, surcout)
}

enum DebtStatus {
  ACTIVE // dette en cours, pas encore d'echeance depassee
  PARTIALLY_PAID // paiement(s) effectue(s) mais pas solde
  CLEARED // soldee (remainingAmount = 0)
  OVERDUE // echeance depassee (calcul cron)
  LITIGATED // contestee : pas de relance auto, fige le statut
  CANCELLED // annulee par admin avec voidReason
}

// Categorie metier de la dette (pour rapports + filtres).
enum DebtCategory {
  FREIGHT // Fret / transport principal
  CUSTOMS // Douane / taxes import-export
  STORAGE // Magasinage / surestaries
  DELIVERY // Livraison finale / dernier kilometre
  TRANSIT // Frais de transit / dossier
  PENALTY // Penalite / amende
  ADVANCE // Avance client
  TRANSPORT // Cout transporteur (dette envers carrier)
  SUPPLY // Fourniture / consommables
  PORT_FEES // Frais portuaires
  FUEL // Carburant
  LABOR // Main d'oeuvre / manutention
  TAXES // Taxes diverses
  MAINTENANCE // Entretien materiel / vehicule
  RENT // Loyer / bail
  OTHER // Autre / non categorise
}

enum DebtPriority {
  LOW
  MEDIUM
  CRITICAL
}

// ============================================================
// Paiements de dette : ne JAMAIS modifier Debt directement.
// Chaque paiement = une ligne ici, le solde est recalcule par le use case.
// ============================================================
model DebtPayment {
  id                   String  @id @default(uuid())
  reference            String  @unique
  debtId               String
  amount               Decimal @db.Decimal(15, 2)
  // String libre referencant PaymentMethodConfig.code (idem Payment).
  paymentMethod        String
  // Justificatif (image ou PDF) : URL MinIO + key pour suppression/rotation.
  proofUrl             String?
  proofKey             String?
  // Reference externe (transaction MoMo, virement bancaire, n° cheque).
  transactionReference String?
  comment              String?
  receivedByUserId     String
  agencyId             String
  // Caisse depuis laquelle le paiement a ete encaisse (cas dette client) ou
  // depuis laquelle on a paye (cas dette personnel/agence/carrier).
  cashRegisterId       String?

  // Immutabilite -- pour corriger, on annule + cree un nouveau paiement.
  isVoided       Boolean   @default(false)
  voidedAt       DateTime?
  voidReason     String?
  voidedByUserId String?

  createdAt DateTime @default(now())

  debt         Debt                @relation(fields: [debtId], references: [id], onDelete: Cascade)
  agency       Agency              @relation(fields: [agencyId], references: [id])
  receivedBy   User                @relation("DebtPaymentReceivedBy", fields: [receivedByUserId], references: [id])
  voidedBy     User?               @relation("DebtPaymentVoidedBy", fields: [voidedByUserId], references: [id])
  cashRegister AgencyCashRegister? @relation(fields: [cashRegisterId], references: [id])

  @@index([debtId])
  @@index([agencyId])
  @@index([createdAt])
  @@map("debt_payments")
}

// ============================================================
// Audit des modifications de dette : tout changement (ajustement montant,
// changement echeance, changement statut, annulation) est trace ici.
// ============================================================
model DebtHistory {
  id        String   @id @default(uuid())
  debtId    String
  action    String // 'CREATED' | 'ADJUSTED' | 'PAYMENT_RECORDED' | 'PAYMENT_VOIDED' | 'STATUS_CHANGED' | 'DUE_DATE_CHANGED' | 'CANCELLED'
  // Snapshot avant/apres pour les champs modifies, sous forme libre JSON.
  // Ex: { field: 'totalAmount', before: 100000, after: 120000 }.
  changes   Json?
  comment   String?
  userId    String?
  createdAt DateTime @default(now())

  debt Debt  @relation(fields: [debtId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@index([debtId])
  @@index([createdAt])
  @@map("debt_histories")
}

// ============================================================
// Transporteurs : entites tiers qui assurent un tronçon de transit.
// Permet d'imputer dettes / decaissements / benefices a un transporteur
// nomme, distinct des agences internes.
// ============================================================
model Carrier {
  id                       String   @id @default(uuid())
  organizationId           String
  name                     String
  contactName              String?
  phone                    String?
  email                    String?
  address                  String?
  // Type d'activite (terrestre, maritime, aerien, multi). Texte libre pour
  // ne pas contraindre prematurement.
  carrierType              String?
  notes                    String?
  // Contact d'urgence (optionnel) : personne a joindre en cas de probleme.
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?
  // Client associe automatiquement : permet d'imputer des paiements /
  // dettes / decaissements au transporteur via la mecanique Client standard.
  clientId                 String?  @unique
  isActive                 Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  client       Client?      @relation(fields: [clientId], references: [id])
  debts        Debt[]
  containers   Container[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([isActive])
  @@map("carriers")
}

// ============================================================
// COMPTABILITE
// ============================================================

model AccountingAccount {
  id             String      @id @default(uuid())
  organizationId String
  code           String      @unique
  name           String
  type           AccountType
  parentId       String?
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id])
  parent       AccountingAccount?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children     AccountingAccount[] @relation("AccountHierarchy")
  debitLines   JournalEntryLine[]  @relation("DebitAccount")
  creditLines  JournalEntryLine[]  @relation("CreditAccount")

  @@index([organizationId])
  @@map("accounting_accounts")
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

model JournalEntry {
  id              String            @id @default(uuid())
  reference       String            @unique
  description     String
  date            DateTime          @default(now())
  agencyId        String
  createdByUserId String
  sourceType      JournalSourceType
  sourceId        String

  // Immutabilite
  isReversed        Boolean @default(false)
  reversedByEntryId String? @unique

  createdAt DateTime @default(now())
  // PAS de updatedAt -- immutable

  agency       Agency             @relation(fields: [agencyId], references: [id])
  createdBy    User               @relation(fields: [createdByUserId], references: [id])
  lines        JournalEntryLine[]
  reverseEntry JournalEntry?      @relation("ReverseJournalEntry", fields: [reversedByEntryId], references: [id])
  reversedBy   JournalEntry?      @relation("ReverseJournalEntry")

  @@index([agencyId])
  @@index([sourceType, sourceId])
  @@index([date])
  @@map("journal_entries")
}

enum JournalSourceType {
  PAYMENT
  DISBURSEMENT
  TRANSFER
  EXPENSE
  PENALTY
  SALARY
}

model JournalEntryLine {
  id              String   @id @default(uuid())
  journalEntryId  String
  debitAccountId  String?
  creditAccountId String?
  debitAmount     Decimal  @default(0) @db.Decimal(15, 2)
  creditAmount    Decimal  @default(0) @db.Decimal(15, 2)
  description     String?
  createdAt       DateTime @default(now())

  journalEntry  JournalEntry       @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  debitAccount  AccountingAccount? @relation("DebitAccount", fields: [debitAccountId], references: [id])
  creditAccount AccountingAccount? @relation("CreditAccount", fields: [creditAccountId], references: [id])

  @@index([journalEntryId])
  @@map("journal_entry_lines")
}

// ============================================================
// PENALITES
// ============================================================

model Penalty {
  id              String   @id @default(uuid())
  parcelId        String
  agencyId        String
  clientId        String
  startDate       DateTime
  dailyRate       Decimal  @db.Decimal(15, 2)
  daysAccumulated Int      @default(0)
  totalAmount     Decimal  @default(0) @db.Decimal(15, 2)
  isPaid          Boolean  @default(false)
  invoiceId       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  parcel Parcel @relation(fields: [parcelId], references: [id])
  agency Agency @relation(fields: [agencyId], references: [id])
  client Client @relation(fields: [clientId], references: [id])

  @@index([parcelId])
  @@index([clientId])
  @@map("penalties")
}

// ============================================================
// BORDEREAUX
// ============================================================

model ShippingManifest {
  id          String         @id @default(uuid())
  containerId String
  number      String         @unique
  type        ManifestType
  status      ManifestStatus @default(ACTIVE)
  closedAt    DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  container Container      @relation(fields: [containerId], references: [id])
  lines     ManifestLine[]

  @@index([containerId])
  @@map("shipping_manifests")
}

enum ManifestType {
  DISPATCH
  RECEPTION
}

enum ManifestStatus {
  ACTIVE
  ARCHIVED
  CANCELLED
}

model ManifestLine {
  id              String   @id @default(uuid())
  manifestId      String
  parcelId        String?
  // Snapshot des donnees du colis au moment de l'emission (immuable)
  trackingNumber  String?
  designation     String
  clientName      String?
  // Snapshot contact client au moment de l'emission. Indispensable pour les
  // bordereaux destines a un transporteur tiers, qui doit pouvoir contacter
  // l'expediteur sans dependre du systeme.
  clientPhone     String?
  clientEmail     String?
  recipientName   String?
  recipientPhone  String?
  recipientEmail  String?
  destinationCity String?
  weight          Decimal? @db.Decimal(15, 4)
  volume          Decimal? @db.Decimal(15, 4)
  origin          String?
  destination     String?
  transit         String?
  price           Decimal  @default(0) @db.Decimal(15, 2)
  // montant total facture (peut etre > price si la facture couvre plusieurs colis)
  invoiceTotal    Decimal? @db.Decimal(15, 2)
  // avance / montant deja paye attribue a ce colis
  advanceAmount   Decimal  @default(0) @db.Decimal(15, 2)
  // reste a payer
  balanceAmount   Decimal  @default(0) @db.Decimal(15, 2)
  status          String?
  addedAt         DateTime @default(now())

  manifest ShippingManifest @relation(fields: [manifestId], references: [id], onDelete: Cascade)
  parcel   Parcel?          @relation(fields: [parcelId], references: [id])

  @@index([manifestId])
  @@map("manifest_lines")
}

// Ecarts marques par l'admin lors de la reception d'un conteneur
// (colis presents physiquement mais pas en ligne, ou en ligne mais absents physiquement)
model ManifestDiscrepancy {
  id             String          @id @default(uuid())
  containerId    String
  parcelId       String?
  type           DiscrepancyType
  designation    String?
  trackingNumber String?
  weight         Decimal?        @db.Decimal(15, 4)
  comment        String?
  markedByUserId String?
  createdAt      DateTime        @default(now())

  container Container @relation(fields: [containerId], references: [id])
  parcel    Parcel?   @relation(fields: [parcelId], references: [id])

  @@index([containerId])
  @@index([type])
  @@map("manifest_discrepancies")
}

enum DiscrepancyType {
  MISSING_PHYSICAL // declare en ligne mais absent physiquement
  EXTRA_PHYSICAL // present physiquement mais non enregistre en ligne
}

// ============================================================
// HISTORIQUE / AUDIT
// ============================================================

model ParcelHistory {
  id                        String   @id @default(uuid())
  parcelId                  String
  action                    String
  statusBefore              String?
  statusAfter               String?
  wasPresentBefore          Boolean?
  isPresentAfter            Boolean?
  locationBefore            String?
  locationAfter             String?
  warehouseId               String?
  containerId               String?
  transitRouteId            String?
  userId                    String?
  actorType                 String?
  actorName                 String?
  parcelDesignationSnapshot String?
  parcelTrackingSnapshot    String?
  comment                   String?
  metadata                  Json?
  createdAt                 DateTime @default(now())

  parcel    Parcel     @relation(fields: [parcelId], references: [id])
  user      User?      @relation(fields: [userId], references: [id])
  container Container? @relation(fields: [containerId], references: [id])
  warehouse Warehouse? @relation("ParcelHistoryWarehouse", fields: [warehouseId], references: [id])

  @@index([parcelId])
  @@index([createdAt])
  @@map("parcel_histories")
}

model ContainerHistory {
  id           String   @id @default(uuid())
  containerId  String
  action       String
  statusBefore String?
  statusAfter  String?
  changes      Json?
  userId       String?
  actorType    String?
  actorName    String?
  comment      String?
  createdAt    DateTime @default(now())

  container Container @relation(fields: [containerId], references: [id])
  user      User?     @relation(fields: [userId], references: [id])

  @@index([containerId])
  @@index([createdAt])
  @@map("container_histories")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  agencyId   String?
  action     String
  entityType String
  entityId   String?
  changes    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  agency Agency? @relation(fields: [agencyId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String             @id @default(uuid())
  // Scope tenant : permet au centre de notifications de filtrer sans JOIN
  // sur agency/client/user. Nullable pour les anciens rows.
  organizationId String?
  userId    String?
  clientId  String?
  agencyId  String?
  title     String
  message   String
  type      NotificationType
  status    NotificationStatus @default(PENDING)
  // Nature de l'evenement metier (PARCEL_CREATED, PAYMENT_RECEIVED, ...).
  // Stocke aussi dans metadata.kind ; colonne dediee pour le filtrage.
  eventKind String?
  // Destinataire effectif (email / telephone / token) pour le canal.
  recipient String?
  // Message d'erreur du dernier echec (pour le centre de notifications).
  error     String?
  // Pieces jointes envoyees (URL + filename + caption), au format
  // NotificationAttachment[]. Permet de rejouer/afficher les fichiers.
  attachments Json?
  // Suivi des retentatives manuelles depuis le centre de notifications.
  retryCount Int             @default(0)
  lastRetryAt DateTime?
  sentAt    DateTime?
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime           @default(now())

  agency Agency? @relation(fields: [agencyId], references: [id])
  client Client? @relation("ClientNotifications", fields: [clientId], references: [id])

  @@index([userId])
  @@index([clientId])
  @@index([status])
  @@index([organizationId])
  @@index([eventKind])
  @@index([type])
  @@index([createdAt])
  @@map("notifications")
}

enum NotificationType {
  EMAIL
  SMS
  WHATSAPP
  PUSH
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

// ============================================================
// NOTIFICATION TEMPLATES (par tenant, par event, par canal)
// ============================================================

/**
 * Template de notification personnalisé par le tenant admin.
 * Un template overrides le message par défaut du système pour un triplet
 * (organizationId, eventKind, channel).
 *
 * Le body est un template Handlebars avec les variables de l'event.
 * Ex : "Bonjour {{clientName}}, votre colis {{trackingNumber}} est arrivé !"
 */
model TenantNotificationTemplate {
  id             String   @id @default(cuid())
  organizationId String
  eventKind      String
  channel        String
  subject        String?
  body           String   @db.Text
  /** JSON : { invoice: bool, receipt: bool, parcelLabel: bool } */
  attachments    Json?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, eventKind, channel])
  @@index([organizationId])
  @@map("tenant_notification_templates")
}

// ============================================================
// WHATSAPP PERSONAL CHANNEL (API WhatsApp interne / Baileys)
// ============================================================

/**
 * Config de la session WhatsApp d'un tenant sur l'API WhatsApp interne
 * (whatsapp-api.transitsoftservices.com, moteur Baileys, multi-sessions).
 *
 * Le QR / la connexion se gerent sur le dashboard externe
 * (whatsapp-dashboard.transitsoftservices.com) qui delivre une CLE API scopee
 * a la session. Ici on ne stocke que les variables de connexion du client :
 * la cle API (par tenant) et une base URL optionnelle (sinon config.whatsapp.apiUrl).
 * Les notifications du tenant partent via cette session quand `enabled`.
 */
model TenantWhatsAppSession {
  id             String    @id @default(cuid())
  organizationId String    @unique
  /** Canal WhatsApp personnel activé pour ce tenant. */
  enabled        Boolean   @default(false)
  /** Clé API de la session (header x-api-key vers l'API WhatsApp interne). */
  apiKey         String?   @db.Text
  /** Base URL de l'API WhatsApp (override). Vide => config.whatsapp.apiUrl global. */
  baseUrl        String?
  /** Dernier numéro connecté connu (rafraîchi via GET /v1/session). */
  connectedPhone String?
  /** Dernier statut de session renvoyé par l'API externe (ex: connected, qr, disconnected). */
  lastStatus     String?
  /** Dernière erreur de connexion / d'envoi. */
  lastError      String?
  /** Dernier check de statut auprès de l'API externe. */
  lastCheckedAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("tenant_whatsapp_sessions")
}

// ABAC Phase 2 : traçabilité des uploads pour scoping objet.
// Chaque fichier uploade est lie a une org. getObject verifie l appartenance.
// Les cles anterieures (sans ligne) sont tolerees (backward compat).
model UploadObject {
  id             String   @id @default(uuid())
  key            String   @unique
  organizationId String
  uploadedById   String
  uploadedByType String   @default("USER") // "USER" | "CLIENT"
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@map("upload_objects")
}

// ============================================================
// CHAT / SUPPORT
// ============================================================

model ChatConversation {
  id             String             @id @default(uuid())
  clientId       String
  agencyId       String
  assignedUserId String?
  status         ConversationStatus @default(OPEN)
  createdAt      DateTime           @default(now())
  closedAt       DateTime?

  client       Client        @relation(fields: [clientId], references: [id])
  agency       Agency        @relation(fields: [agencyId], references: [id])
  assignedUser User?         @relation(fields: [assignedUserId], references: [id])
  messages     ChatMessage[]

  @@index([clientId])
  @@index([status])
  @@map("chat_conversations")
}

enum ConversationStatus {
  OPEN
  CLOSED
}

model ChatMessage {
  id             String    @id @default(uuid())
  conversationId String
  // Author identifiers (mutually exclusive). senderType discriminates:
  // 'USER' -> senderUserId set ; 'CLIENT' -> senderClientId set ; 'SYSTEM' -> both null.
  senderUserId   String?
  senderClientId String?
  senderType     String
  message        String
  isRead         Boolean   @default(false)
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUser   User?            @relation(fields: [senderUserId], references: [id])
  senderClient Client?          @relation("ClientChatMessages", fields: [senderClientId], references: [id])

  @@index([conversationId])
  @@index([createdAt])
  @@map("chat_messages")
}

// ============================================================
// FIDELITE
// ============================================================

model LoyaltyTransaction {
  id          String   @id @default(uuid())
  clientId    String
  points      Int
  type        String
  source      String?
  description String?
  createdAt   DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@map("loyalty_transactions")
}

model LoyaltyTierConfig {
  id              String   @id @default(uuid())
  organizationId  String
  name            String
  minPoints       Int
  discountPercent Decimal  @db.Decimal(5, 2)
  benefits        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, name])
  @@map("loyalty_tier_configs")
}

// ============================================================
// DEVISES
// ============================================================

model Currency {
  id             String   @id @default(uuid())
  organizationId String
  code           String
  name           String
  symbol         String
  exchangeRate   Decimal  @db.Decimal(15, 6)
  isBase         Boolean  @default(false)
  isActive       Boolean  @default(true)
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, code])
  @@map("currencies")
}

// ============================================================
// CONFIGURATION SYSTEME
// ============================================================

model SystemConfig {
  id             String   @id @default(uuid())
  organizationId String
  key            String
  value          String
  description    String?
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, key])
  @@map("system_configs")
}

// ============================================================
// RH PHASE 1 : POSTES, PERMISSIONS, PLANNINGS, JOURS NON OUVRES
// ============================================================

// Catalogue des postes au sein d'une agence ou de l'organisation.
// Chaque Employee est rattache a un Position ; les permissions ABAC sont
// portees par PositionPermission. SUPER_ADMIN n'est PAS un poste : il reste
// porte par User.role et n'a pas d'Employee.
model Position {
  id             String   @id @default(uuid())
  organizationId String
  // Si renseigne : poste specifique a une agence (ex : "Chef d'agence Douala").
  // Si NULL : poste global a l'organisation (catalogue standard).
  agencyId       String?
  name           String
  description    String?
  // Niveau hierarchique (1 = direction, plus eleve = plus haut). Utilise pour
  // les statistiques et la chaine de validation.
  hierarchyLevel Int      @default(50)
  // Postes systeme seedes (non supprimables via UI). Permet de reseter sans casser.
  isSystem       Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  agency      Agency?              @relation(fields: [agencyId], references: [id])
  employees   Employee[]
  permissions PositionPermission[]

  @@unique([organizationId, agencyId, name])
  @@index([organizationId])
  @@index([agencyId])
  @@map("positions")
}

// Catalogue des permissions ABAC. Cle stable (ex: "attendance.mark") pour
// referencement cote code ; libelle/description pour l'UI admin.
model Permission {
  id          String   @id @default(uuid())
  key         String   @unique
  label       String
  description String?
  // Categorie d'affichage (ex: "personnel", "finance", "colis", "agence").
  category    String
  isSystem    Boolean  @default(true)
  createdAt   DateTime @default(now())

  positions PositionPermission[]
  overrides UserPermissionOverride[]

  @@index([category])
  @@map("permissions")
}

// Matrice poste -> permission. La table de jointure portee par l'admin.
model PositionPermission {
  positionId   String
  permissionId String
  createdAt    DateTime @default(now())

  position   Position   @relation(fields: [positionId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([positionId, permissionId])
  @@index([permissionId])
  @@map("position_permissions")
}

// Override individuel : ajout (granted=true) ou retrait (granted=false) d'une
// permission par rapport au poste. Permet d'octroyer ou de retirer ponctuellement
// un droit a un User sans modifier la matrice du poste.
model UserPermissionOverride {
  id           String   @id @default(uuid())
  userId       String
  permissionId String
  granted      Boolean
  reason       String?
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([userId])
  @@map("user_permission_overrides")
}

// Planning RH : conteneur d'horaires applique soit a une agence (planning par
// defaut) soit a un employe (override). Distinct des heures d'ouverture
// commerciale (AgencyOpeningHours).
model WorkSchedule {
  id          String   @id @default(uuid())
  name        String
  description String?
  // Fuseau horaire IANA pour l'interpretation des heures (heritage agence si NULL).
  timezone    String?
  isActive    Boolean  @default(true)
  // Isolation multi-tenant. NULLABLE pour l'instant : les lignes existantes n'ont
  // pas d'organisation, une colonne NOT NULL casserait la migration/backfill.
  // A rendre obligatoire (String, sans ?) apres le backfill des lignes existantes.
  organizationId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  days      WorkScheduleDay[]
  agencies  Agency[]          @relation("AgencyWorkSchedule")
  employees Employee[]        @relation("EmployeeSchedule")

  @@index([organizationId])
  @@map("work_schedules")
}

// Jour-par-jour d'un planning. dayOfWeek 0 (dim) .. 6 (sam).
// isWorking=false : jour de repos ; les champs heure sont alors ignores.
model WorkScheduleDay {
  id           String  @id @default(uuid())
  scheduleId   String
  dayOfWeek    Int
  startTime    String?
  endTime      String?
  // Pause non remuneree au milieu de la journee (en minutes). Optionnel.
  breakMinutes Int     @default(0)
  isWorking    Boolean @default(true)

  schedule WorkSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, dayOfWeek])
  @@index([scheduleId])
  @@map("work_schedule_days")
}

// Jours non ouvres : ferie national, fermeture exceptionnelle d'agence, repos
// individuel d'un employe. Un seul modele couvre les 3 portees via le champ
// scope + agencyId/employeeId.
//   - GLOBAL : agencyId=null, employeeId=null  (organisation entiere)
//   - AGENCY : agencyId=set,  employeeId=null
//   - EMPLOYEE : agencyId=null, employeeId=set
// Pour un groupe d'employes, creer N entrees EMPLOYEE.
model Holiday {
  id             String       @id @default(uuid())
  organizationId String
  scope          HolidayScope
  agencyId       String?
  employeeId     String?
  name           String
  // Plage de dates inclusives. fromDate=toDate pour un seul jour.
  fromDate       DateTime     @db.Date
  toDate         DateTime     @db.Date
  // Recurrent annuel (ex: 1er janvier). Si true, l'annee est ignoree au matching.
  isRecurring    Boolean      @default(false)
  reason         String?
  createdAt      DateTime     @default(now())

  agency   Agency?   @relation("AgencyHoliday", fields: [agencyId], references: [id], onDelete: Cascade)
  employee Employee? @relation("EmployeeHoliday", fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([agencyId])
  @@index([employeeId])
  @@index([fromDate, toDate])
  @@map("holidays")
}

enum HolidayScope {
  GLOBAL
  AGENCY
  EMPLOYEE
}

// Affectation historicisee d'un employe a une agence. Permet le suivi
// multi-agences et les transferts. L'agence "courante" reste portee par
// Employee.agencyId pour les requetes simples ; cette table porte l'historique.
model EmployeeAgencyAssignment {
  id         String    @id @default(uuid())
  employeeId String
  agencyId   String
  isPrimary  Boolean   @default(false)
  fromDate   DateTime  @db.Date
  toDate     DateTime? @db.Date
  reason     String?
  createdAt  DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  agency   Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([agencyId])
  @@index([fromDate, toDate])
  @@map("employee_agency_assignments")
}

// ============================================================
// PARCEL STORAGE CHARGES
// ============================================================
// Tracage explicite des frais de magasinage par colis + magasin + phase.
// Une "charge" = periode pendant laquelle un colis a ete stocke dans un
// magasin (avec sa propre regle freeDays/dailyRate snapshotee). On ouvre une
// charge a l'entree du magasin, on la ferme a la sortie / paiement /
// chargement / livraison. Une facture = somme des charges associees.
model ParcelStorageCharge {
  id          String       @id @default(uuid())
  parcelId    String
  warehouseId String
  agencyId    String
  // Snapshot regle au moment du start (evite drift si regle modifiee apres)
  dailyRate   Decimal      @db.Decimal(15, 2)
  freeDays    Int          @default(0)
  ruleLabel   String?
  // Phase du voyage : determine la politique (gracePeriod ou non, applicable
  // ou non). DEPARTURE = magasin avant transit, TRANSIT = arret intermediaire
  // (jamais facture), DESTINATION = magasin destination finale.
  phase       StoragePhase
  // Periode
  startedAt   DateTime
  stoppedAt   DateTime?
  // Raison du stop (audit) : PAYMENT, CONTAINER_DEPART, TRANSFER,
  // HANDOVER, MANUAL.
  stopReason  String?
  // Sortie recomputable a la lecture, materialisee au stop pour eviter recalc.
  chargedDays Int          @default(0)
  feeAmount   Decimal      @default(0) @db.Decimal(15, 2)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  parcel    Parcel    @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  agency    Agency    @relation(fields: [agencyId], references: [id])

  @@index([parcelId])
  @@index([warehouseId])
  @@index([agencyId])
  @@index([parcelId, stoppedAt])
  @@map("parcel_storage_charges")
}

enum StoragePhase {
  DEPARTURE
  TRANSIT
  DESTINATION
}
