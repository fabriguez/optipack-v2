// ============================================================
// BONS DE DECAISSEMENT (IMMUTABLE)
// ============================================================

model DisbursementVoucher {
  id                       String  @id @default(uuid())
  reference                String  @unique
  agencyId                 String
  cashRegisterId           String
  reason                   String
  description              String?
  // Ordonnateur : nom snapshote (immutable, garde la trace meme si l'employe
  // est supprime/renomme). ordererUserId reference l'utilisateur reel pour
  // navigation (cliquable vers /employees/:id si l'utilisateur est un employe).
  orderer                  String
  ordererUserId            String?
  amount                   Decimal @db.Decimal(15, 2)
  amountInWords            String
  // proofUrl : justificatif principal (PDF, jpg, png). Stocke dans MinIO.
  // proofKey : cle objet MinIO pour pouvoir le remplacer/supprimer ; utile
  // pour l'audit interne. justificationDescription : commentaire libre sur
  // le justificatif (facture, recu, devis, ...).
  proofUrl                 String?
  proofKey                 String?
  justificationDescription String?
  // Liens optionnels : pour les decaissements de remboursement ou de charge
  // attribuable a un conteneur / colis / client specifique. Au moins zero
  // ou un de ces trois liens peut etre defini (independants).
  containerId              String?
  parcelId                 String?
  clientId                 String?
  issuedByUserId           String
  approvedByUserId         String?

  // Immutabilite
  isVoided       Boolean   @default(false)
  voidedAt       DateTime?
  voidReason     String?
  reverseEntryId String?   @unique

  createdAt DateTime @default(now())
  // PAS de updatedAt -- immutable

  agency       Agency                   @relation(fields: [agencyId], references: [id])
  cashRegister AgencyCashRegister       @relation(fields: [cashRegisterId], references: [id])
  ordererUser  User?                    @relation("OrdererUser", fields: [ordererUserId], references: [id])
  container    Container?               @relation(fields: [containerId], references: [id])
  parcel       Parcel?                  @relation(fields: [parcelId], references: [id])
  client       Client?                  @relation(fields: [clientId], references: [id])
  issuedBy     User                     @relation("IssuedByUser", fields: [issuedByUserId], references: [id])
  approvedBy   User?                    @relation("ApprovedByUser", fields: [approvedByUserId], references: [id])
  reverseEntry DisbursementVoucher?     @relation("ReverseVoucher", fields: [reverseEntryId], references: [id])
  reversedBy   DisbursementVoucher?     @relation("ReverseVoucher")
  // Lien inverse vers la depense (Expense) qui a declenche ce decaissement.
  // Permet la dedup dans le rapport journalier (cf Expense.disbursementId).
  expense      Expense?                 @relation("ExpenseDisbursement")
  // Pieces jointes additionnelles (images / PDF de preuve).
  attachments  DisbursementAttachment[]

  @@index([agencyId])
  @@index([cashRegisterId])
  @@index([containerId])
  @@index([parcelId])
  @@index([clientId])
  @@map("disbursement_vouchers")
}

model DisbursementAttachment {
  id               String   @id @default(uuid())
  disbursementId   String
  url              String
  key              String
  kind             String // 'IMAGE' | 'PDF' | 'OTHER'
  caption          String?
  uploadedByUserId String?
  createdAt        DateTime @default(now())

  disbursement DisbursementVoucher @relation(fields: [disbursementId], references: [id], onDelete: Cascade)
