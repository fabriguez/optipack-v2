# pnpm strict-isolation casse Metro qui cherche @react-native/* depuis
# le node_modules de l'app, mais ces packages sont nested dans .pnpm/<hash>.
# Hoist explicite vers les node_modules d'app pour que Metro les trouve.
public-hoist-pattern[]=@react-native/*
public-hoist-pattern[]=react-native
public-hoist-pattern[]=*react-native*
# Metro/Expo (getDefaultConfig -> getAssetPlugins) resout expo-asset & co depuis
# le node_modules de l'app : ces paquets sont des deps transitives d'`expo`,
# nested dans .pnpm en isolation stricte. Hoist explicite pour que Metro les
# trouve (sinon "The required package `expo-asset` cannot be found").
public-hoist-pattern[]=*expo*
public-hoist-pattern[]=@expo/*
shamefully-hoist=false
