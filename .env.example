# Database
DATABASE_URL=postgresql://transitsoftservices:transitsoftservices@localhost:5432/transitsoftservices?schema=public
POSTGRES_DB=transitsoftservices
POSTGRES_USER=transitsoftservices
POSTGRES_PASSWORD=transitsoftservices

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9005
MINIO_ACCESS_KEY=transitsoftservices
MINIO_SECRET_KEY=transitsoftservices_secret
MINIO_BUCKET=transitsoftservices
MINIO_ROOT_USER=transitsoftservices
MINIO_ROOT_PASSWORD=transitsoftservices_secret
# URL publique du MinIO (liens presignes notif-center + email). RECOMMANDEE mais
# PLUS requise pour les pieces jointes WhatsApp : celles-ci partent desormais en
# inline base64 (octets lus depuis le MinIO interne), donc marchent meme sans
# MinIO public. Si definie, les URLs sont signees directement contre ce host
# (signature SigV4 valide). Ex prod principal : https://s3.transitsoftservices.com
MINIO_PUBLIC_BASE_URL=

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Email (Gmail avec App Password)
# 1. Aller sur https://myaccount.google.com/apppasswords
# 2. Generer un mot de passe d'application pour "Mail"
# 3. Coller le mot de passe genere dans SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre-email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM=TransitSoftServices <votre-email@gmail.com>

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stream Chat (support client temps reel) — getstream.io dashboard
STREAM_API_KEY=
STREAM_API_SECRET=

# ============================================================
# NOTIFICATIONS — canaux externes
# ============================================================

# WhatsApp : chaine de fallback ordonnee. Le canal PRIORITAIRE reste l'API
# WhatsApp interne PERSONNELLE du tenant (clé par organisation) ; cette chaine
# n'est tentee qu'en fallback. Mettre 'wapino' en tete = fallback juste apres.
# Valeurs possibles : wapino | twilio | meta | africas-talking | log
# 'log' = stub dev (aucun envoi reel, log dans la console)
WHATSAPP_PROVIDER_CHAIN=wapino,log

# Twilio WhatsApp
# https://www.twilio.com/docs/whatsapp/api
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=+14155238886

# Wapino WhatsApp GLOBAL (https://wapino.consolidis.com, doc /docs) — compte
# plateforme partage, dernier recours du provider chain. Le fallback Wapino
# PAR TENANT se configure dans le backoffice : Parametres > Wapino (stocke en
# base, TenantWapinoConfig) et il est tente AVANT ce chain.
# Cle : dashboard Wapino > Parametres > Cles API. Auth Bearer.
WAPINO_API_KEY=wp_live_
# Nom de l'instance Wapino (requis pour l'envoi de medias/send-media ;
# vide = endpoint legacy /message/send, texte uniquement).
WAPINO_INSTANCE=NomDeVotreInstance
# Vide = https://api.wapino.consolidis.com/v1
WAPINO_BASE_URL=

# Meta Cloud API WhatsApp (optionnel, alternative a Twilio/Wapino)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_VERIFY_TOKEN=

# Canal WhatsApp personnel — API WhatsApp interne (Baileys) deployee.
# Base URL globale ; la cle API est configuree PAR TENANT dans
# Parametres > WhatsApp Personnel (une session par organisation, generee sur
# le dashboard whatsapp-dashboard.transitsoftservices.com).
WA_API_URL=https://whatsapp-api.transitsoftservices.com

# SMS provider : africas-talking | twilio | vonage | log
SMS_PROVIDER=log

# Africa's Talking (SMS + WhatsApp)
AT_USERNAME=sandbox
AT_API_KEY=
AT_SMS_FROM=
AT_SMS_SANDBOX=true
AT_WA_FROM=
AT_WA_SANDBOX=true

# Push notifications (mobile)
# expo = Expo Push API (aucune credential serveur ; requires EAS_PROJECT_ID cote app)
# log  = stub dev
PUSH_PROVIDER=log

# Mobile Money
MOBILE_MONEY_API_KEY=xxx
MOBILE_MONEY_API_SECRET=xxx

# NextAuth
AUTH_SECRET=generate-a-random-secret-here
AUTH_URL=http://localhost:3000

# App
NODE_ENV=development
API_PORT=4000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
INTERNAL_API_URL=http://localhost:4000/api/v1
WEB_URL=http://localhost:3000

# ============================================================
# CONTROL PLANE (orchestrator) — separe du tenant API
# ============================================================
OPS_PORT=4020
OPS_DATABASE_URL=postgresql://opsadmin:opsadmin_password@localhost:5433/ops_admin?schema=public
OPS_POSTGRES_USER=opsadmin
OPS_POSTGRES_PASSWORD=opsadmin_password
OPS_POSTGRES_DB=ops_admin
OPS_REDIS_URL=redis://localhost:6380
OPS_JWT_SECRET=generate-with-openssl-rand-hex-32
OPS_JWT_ACCESS_EXPIRY=1h
# Cle maitre AES-256-GCM pour chiffrer les SSH keys des VPS
# Generer avec : openssl rand -hex 32
OPS_MASTER_KEY=generate-with-openssl-rand-hex-32
OPS_BCRYPT_ROUNDS=10
OPS_TOTP_ISSUER=TransitSoftServices Ops
# GHCR (pour pull les images optipack-api/web sur les VPS tenants)
OPS_GHCR_NAMESPACE=transitsoftservices
OPS_GHCR_TOKEN=ghp_xxx
OPS_PUBLIC_WEB_URL=http://localhost:3020
# CORS pour ops-admin frontend (csv). Vide en dev = autorise tout. Bloque en prod.
OPS_CORS_ORIGINS=https://ops-admin.transitsoftservices.com

# Seed initial du super-admin (utilise par `pnpm --filter orchestrator seed`)
SEED_OPS_ADMIN_EMAIL=admin@transitsoftservices.com
SEED_OPS_ADMIN_PASSWORD=changeme-generate-with-openssl-rand-hex-16
SEED_OPS_ADMIN_NAME=Ops Super Admin

# Tenant identification (pour /tenant-meta cote API tenant)
# Sur un VPS multi-tenant, le subdomain identifie le tenant. En dev, fixer ici.
TENANT_SLUG=transitsoftservices
