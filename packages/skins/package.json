{
  "name": "@transitsoftservices/skins",
  "version": "0.1.0",
  "private": true,
  "description": "Shared skin system (themes/palettes) used by the web-client public site, staff web, and validated by the orchestrator.",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./palette": {
      "types": "./src/palette.ts",
      "default": "./dist/palette.js"
    },
    "./apply": {
      "types": "./src/apply.ts",
      "default": "./dist/apply.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@transitsoftservices/tsconfig": "workspace:*",
    "typescript": "^5.7.3"
  }
}
